{
  // Sub-agent config: submodule-dev-restore
  // Restores submodule to dev tip during cleanup
  "name": "submodule-dev-restore",
  "type": "sub-agent",
  "description": "Restores a submodule to its dev branch tip during cleanup. Performs git checkout dev, git pull origin dev --ff-only inside the submodule path.",
  "model": "general",
  "tools": ["bash", "github_*"],
  "dispatch_context": {
    "must_receive": [
      "submodule_path",
      "parent_repo_path",
      "branch"
    ],
    "must_not_receive": [
      "orchestrator reasoning",
      "expected outcomes",
      "cached git state",
      "pre-determined branch names",
      "content verification results",
      "tag data",
      "any information about branches to delete"
    ]
  },
  "boundary": "scoped submodule operations only — git checkout, git pull, git branch verification. No branch deletion. No tag operations. No parent repo modifications."
}
