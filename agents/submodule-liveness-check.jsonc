{
  // Sub-agent config: submodule-liveness-check
  // Verifies submodule hash reachability at PR time
  "name": "submodule-liveness-check",
  "type": "sub-agent",
  "description": "Performs report-only liveness verification at PR time. Compares committed submodule SHAs against remote dev HEAD SHAs and returns PASS/FAIL per submodule. No auto-remediation. No SHA bumps. No commits.",
  "model": "general",
  "tools": ["bash", "github_*"],
  "dispatch_context": {
    "must_receive": [
      "github.owner",
      "github.repo",
      "github.platform",
      "branch"
    ],
    "must_not_receive": [
      "pre-determined SHA values or expected outcomes",
      "orchestrator reasoning about which submodules should pass/fail",
      "tool recipes, inline commands, or expected line numbers"
    ]
  },
  "boundary": "scoped submodule operations only — read-only liveness check. No commits. No pushes. No SHA bumps. No auto-remediation."
}
