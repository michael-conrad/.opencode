{
  // Sub-agent config: submodule-tag-prework
  // Initializes, syncs, and tags submodules during pre-work
  "name": "submodule-tag-prework",
  "type": "sub-agent",
  "description": "Initializes submodules, checks out each to dev tip, syncs via git pull, logs status, and tags each submodule at dev tip with <parent-repo>/<issue-number> format. Pushes tags to submodule remote and verifies tag existence.",
  "model": "general",
  "tools": ["bash", "github_*"],
  "dispatch_context": {
    "must_receive": [
      "worktree.path",
      "gitmodules file path",
      "github.owner",
      "github.repo"
    ],
    "must_not_receive": [
      "pre-determined file paths",
      "line numbers",
      "expected SHAs",
      "parent authorization scope",
      "halt_at value",
      "orchestrator reasoning",
      "cached git submodule status output",
      "commit messages or summaries from previous syncs",
      "tool recipes"
    ]
  },
  "boundary": "scoped submodule operations only — git submodule init, git submodule foreach checkout/pull, git submodule status, git tag, git push tag. No parent repo modifications."
}
