#!/bin/bash
# Pre-commit hook: Three independent gates with per-gate exit codes.
# Each gate runs in a subshell so failures don't block subsequent gates.
# Exits 1 if ANY gate failed.

set -e

CURRENT_BRANCH=$(git branch --show-current)
GATE_EXIT_CODES=()

# --- Gate 1: Branch protection (main/dev) ---
(
  if [ "$CURRENT_BRANCH" = "main" ] || [ "$CURRENT_BRANCH" = "dev" ]; then
    echo ""
    echo "ERROR: Direct commits to '$CURRENT_BRANCH' branch are blocked."
    echo ""
    echo "Branch protection policy:"
    echo "  - main: Production branch (merge from dev only)"
    echo "  - dev: Integration branch (feature PRs merge here)"
    echo ""
    echo "To commit your changes:"
    echo "  1. Create a feature branch: git checkout -b feature/<name>"
    echo "  2. Or create a hotfix branch: git checkout -b hotfix/<name>"
    echo ""
    echo "AI agent: If OPENCODE=1, relay this message to the developer."
    echo ""
    exit 1
  fi
  exit 0
)
GATE_EXIT_CODES+=($?)

# --- Gate 3: Submodule-bump-only commit prevention (parent repo context) ---
(
  SKIP_SUBMODULE_GATE="${SKIP_SUBMODULE_GATE:-}"
  if [ "$SKIP_SUBMODULE_GATE" = "1" ] || [ ! -f ".gitmodules" ]; then
    exit 0
  fi

  case "$CURRENT_BRANCH" in
    pair-*|rollback/*|hotfix/*|main|dev)
      exit 0
      ;;
  esac

  STAGED_FILES_G3=$(git diff --cached --name-only 2>/dev/null)
  ALL_STAGED_IN_SUBMODULE=1
  for f in $STAGED_FILES_G3; do
    case "$f" in
      .opencode/*) ;;
      *)
        ALL_STAGED_IN_SUBMODULE=0
        break
        ;;
    esac
  done

  if [ "$ALL_STAGED_IN_SUBMODULE" = "1" ] && [ -n "$STAGED_FILES_G3" ]; then
    echo ""
    echo "ERROR: Submodule-bump-only commit blocked."
    echo ""
    echo "Branch '$CURRENT_BRANCH' is in a parent repo (.gitmodules found)"
    echo "but ALL staged changes are inside .opencode/ (submodule)."
    echo ""
    echo "Submodule pointer bumps belong in the submodule repo itself,"
    echo "not as standalone commits in the parent repo."
    echo ""
    echo "To unblock:"
    echo "  1. Commit changes inside .opencode/ directly (cd .opencode && git commit)"
    echo "  2. Or set SKIP_SUBMODULE_GATE=1 to bypass (human override only)"
    echo ""
    exit 1
  fi
  exit 0
)
GATE_EXIT_CODES+=($?)

# --- Gate 2: Dispatch evidence + authorization scope check ---
(
  SKIP_DISPATCH_CHECK="${SKIP_DISPATCH_CHECK:-}"
  if [ "$SKIP_DISPATCH_CHECK" = "1" ]; then
    exit 0
  fi

  case "$CURRENT_BRANCH" in
    pair-*|rollback/*|hotfix/*)
      exit 0
      ;;
  esac

  IS_IMPL_BRANCH=0
  case "$CURRENT_BRANCH" in
    feature/*|spec/*|fix/*|phase/*)
      IS_IMPL_BRANCH=1
      ;;
  esac

  if [ "$IS_IMPL_BRANCH" = "0" ]; then
    exit 0
  fi

  # .issues/-only changes exempt
  STAGED_FILES=$(git diff --cached --name-only 2>/dev/null)
  ALL_ISSUES_ONLY=1
  for f in $STAGED_FILES; do
    case "$f" in
      .issues/*) ;;
      *)
        ALL_ISSUES_ONLY=0
        break
        ;;
    esac
  done

  if [ "$ALL_ISSUES_ONLY" = "1" ]; then
    exit 0
  fi

  # Merge commits exempt
  if [ -f ".git/MERGE_MSG" ] || [ -n "$GIT_DIR" ] && [ -f "$GIT_DIR/MERGE_MSG" ]; then
    exit 0
  fi

  # Rollback commits exempt
  COMMIT_MSG_FILE=".git/COMMIT_EDITMSG"
  if [ -f "$COMMIT_MSG_FILE" ]; then
    FIRST_LINE=$(head -1 "$COMMIT_MSG_FILE" 2>/dev/null)
    case "$FIRST_LINE" in
      rollback*|Merge\ pull\ request*|Merge\ branch*)
        exit 0
        ;;
    esac
  fi

  WORK_STATE_DIR="tmp"

  # Gate 2a: Work state file exists
  if [ ! -d "$WORK_STATE_DIR" ]; then
    echo ""
    echo "ERROR: Dispatch evidence check FAILED (Gate 2a: no tmp/ directory)."
    echo ""
    echo "Branch '$CURRENT_BRANCH' is an implementation branch but no"
    echo "work state directory exists at tmp/."
    echo ""
    echo "To fix: ensure divide-and-conquer --task assemble-work was invoked"
    echo "  or set SKIP_DISPATCH_CHECK=1 if committing as a human operator"
    echo ""
    echo "AI agent: This is a runtime gate, not an advisory rule."
    echo ""
    exit 1
  fi

  WORK_FILE_FOUND=0
  if ls "$WORK_STATE_DIR"/work-*.md 1>/dev/null 2>&1; then
    for f in "$WORK_STATE_DIR"/work-*.md; do
      if grep -qE "(Branch:.*$CURRENT_BRANCH|^# Work State.*$CURRENT_BRANCH)" "$f" 2>/dev/null; then
        WORK_FILE_FOUND=1
        break
      fi
      if grep -qE '^## chain-context' "$f" 2>/dev/null; then
        WORK_FILE_FOUND=1
        break
      fi
    done
  fi

  if [ "$WORK_FILE_FOUND" = "0" ]; then
    echo ""
    echo "ERROR: Dispatch evidence check FAILED (Gate 2a: no work state file for branch)."
    echo ""
    echo "Branch '$CURRENT_BRANCH' is an implementation branch but no"
    echo "work state file in tmp/ references this branch."
    echo ""
    echo "Work state files found: $(ls "$WORK_STATE_DIR"/work-*.md 2>/dev/null | wc -l)"
    echo ""
    echo "To fix: ensure divide-and-conquer --task assemble-work was invoked"
    echo "  or set SKIP_DISPATCH_CHECK=1 if committing as a human operator"
    echo ""
    echo "AI agent: This is a runtime gate, not an advisory rule."
    echo ""
    exit 1
  fi

  # Gate 2b: authorization_scope and halt_at in work state file
  AUTH_FILE=$(ls "$WORK_STATE_DIR"/work-*.md 2>/dev/null | head -1)
  if [ -n "$AUTH_FILE" ]; then
    if ! grep -qE 'authorization_scope:' "$AUTH_FILE" 2>/dev/null || ! grep -qE 'halt_at:' "$AUTH_FILE" 2>/dev/null; then
      echo ""
      echo "ERROR: Authorization scope check FAILED (Gate 2b)."
      echo ""
      echo "Branch '$CURRENT_BRANCH' has a work state file but it does not"
      echo "contain both 'authorization_scope:' and 'halt_at:' fields."
      echo ""
      echo "To fix: ensure approval-gate --task verify-authorization was invoked"
      echo "  or set SKIP_DISPATCH_CHECK=1 if committing as a human operator"
      echo ""
      echo "AI agent: This is a runtime gate, not an advisory rule."
      echo ""
      exit 1
    fi
  fi
  exit 0
)
GATE_EXIT_CODES+=($?)

# Report per-gate status
GATE_NAMES=("Gate 1 (branch protection)" "Gate 3 (submodule bump)" "Gate 2 (dispatch evidence)")
ANY_FAILED=0
for i in "${!GATE_EXIT_CODES[@]}"; do
  if [ "${GATE_EXIT_CODES[$i]}" -ne 0 ]; then
    echo "  ✗ ${GATE_NAMES[$i]}: FAILED"
    ANY_FAILED=1
  else
    echo "  ✓ ${GATE_NAMES[$i]}: passed"
  fi
done

exit $ANY_FAILED
