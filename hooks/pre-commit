#!/bin/bash
# Pre-commit hook: Branch protection + dispatch evidence enforcement
# Gate 1: Block direct commits to main/dev branches
# Gate 2: Block commits on implementation branches without dispatch marker
#
# Dispatch marker: .opencode/tmp/dispatch-<branch>.marker
# Created by: divide-and-conquer/assemble-work
# Cleaned up by: git-workflow/cleanup after PR merge
# One gate, one invariant: "the dispatch chain was entered"

set -e

CURRENT_BRANCH=$(git branch --show-current)

# --- Gate 1: Branch protection (main/dev) ---
if [ "$CURRENT_BRANCH" = "main" ] || [ "$CURRENT_BRANCH" = "dev" ]; then
    echo ""
    echo "ERROR: Direct commits to '$CURRENT_BRANCH' branch are blocked."
    echo ""
    echo "Branch protection policy:"
    echo "  - main: Production branch (merge from dev only)"
    echo "  - dev: Integration branch (feature PRs merge here)"
    echo ""
    echo "To commit your changes:"
    echo "  1. Create a feature branch: git checkout -b feature/<name>"
    echo "  2. Or create a hotfix branch: git checkout -b hotfix/<name>"
    echo ""
    echo "AI agent: If OPENCODE=1, relay this message to the developer."
    echo ""
    exit 1
fi

# --- Gate 2: Dispatch evidence check ---
# Implementation branches require a dispatch marker file as evidence
# that divide-and-conquer/assemble-work was invoked.
#
# Exemptions:
#   pair-*    — pair mode works directly
#   rollback/* — rollback operations
#   .issues/-only changes — non-behavioral metadata
#   merge commits — auto-generated
#   rollback/merge commit messages — operational
#   SKIP_DISPATCH_CHECK=1 — human escape hatch
#
# NOT exempted:
#   hotfix/* — goes through assemble-work (AI-driven)
#   simple-work — removed; single path through assemble-work

SKIP_DISPATCH_CHECK="${SKIP_DISPATCH_CHECK:-}"
if [ "$SKIP_DISPATCH_CHECK" = "1" ]; then
    exit 0
fi

case "$CURRENT_BRANCH" in
    pair-*|rollback/*)
        exit 0
        ;;
esac

IS_IMPL_BRANCH=0
case "$CURRENT_BRANCH" in
    feature/*|spec/*|fix/*|hotfix/*|phase/*)
        IS_IMPL_BRANCH=1
        ;;
esac

if [ "$IS_IMPL_BRANCH" = "0" ]; then
    exit 0
fi

# .issues/-only changes are non-behavioral metadata — exempt
STAGED_FILES=$(git diff --cached --name-only 2>/dev/null)
ALL_ISSUES_ONLY=1
for f in $STAGED_FILES; do
    case "$f" in
        .issues/*)
            ;;
        *)
            ALL_ISSUES_ONLY=0
            break
            ;;
    esac
done

if [ "$ALL_ISSUES_ONLY" = "1" ]; then
    exit 0
fi

# Allow merge commits
if [ -f ".git/MERGE_MSG" ] || [ -n "$GIT_DIR" ] && [ -f "$GIT_DIR/MERGE_MSG" ]; then
    exit 0
fi

# Allow rollback/merge commit messages
COMMIT_MSG_FILE=".git/COMMIT_EDITMSG"
if [ -f "$COMMIT_MSG_FILE" ]; then
    FIRST_LINE=$(head -1 "$COMMIT_MSG_FILE" 2>/dev/null)
    case "$FIRST_LINE" in
        rollback*|Merge\ pull\ request*|Merge\ branch*)
            exit 0
            ;;
    esac
fi

# Check for dispatch marker file
# Branch names with '/' are converted to '-' for safe filenames
PROJECT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
SAFE_BRANCH=$(echo "$CURRENT_BRANCH" | tr '/' '-')
MARKER_FILE="$PROJECT_ROOT/.opencode/tmp/dispatch-$SAFE_BRANCH.marker"

if [ ! -f "$MARKER_FILE" ]; then
    echo ""
    echo "ERROR: Dispatch evidence check FAILED."
    echo ""
    echo "Branch '$CURRENT_BRANCH' is an implementation branch but the"
    echo "dispatch marker file does not exist:"
    echo "  .opencode/tmp/dispatch-$SAFE_BRANCH.marker"
    echo ""
    echo "The dispatch chain requires assemble-work to create this marker"
    echo "as evidence that sub-agent dispatch occurred."
    echo ""
    echo "To fix:"
    echo "  1. Ensure divide-and-conquer --task assemble-work was invoked"
    echo "  2. Or set SKIP_DISPATCH_CHECK=1 if committing as a human operator"
    echo ""
    echo "AI agent: This is a runtime gate, not an advisory rule."
    echo ""
    exit 1
fi

exit 0