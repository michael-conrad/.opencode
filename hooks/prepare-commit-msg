#!/bin/bash
# Prepare-commit-msg hook: Detect merge commits on protected branches
#
# This hook runs AFTER pre-merge-commit (if that hook didn't block) and
# BEFORE the commit message editor opens. It provides a second layer of
# defense: if pre-merge-commit is somehow bypassed (e.g., --no-verify),
# this hook detects the merge commit being prepared and blocks it.
#
# The hook checks if the commit being prepared is a merge commit (has a
# MERGE_MSG file) and if the current branch is protected.
#
# Exit 1 to block the commit, exit 0 to allow.

set -e

PROTECTED_BRANCHES="main master dev"
CURRENT_BRANCH=$(git branch --show-current)

# Only check for merge commits (when .git/MERGE_MSG exists)
MERGE_MSG_FILE=""
if [ -f ".git/MERGE_MSG" ]; then
    MERGE_MSG_FILE=".git/MERGE_MSG"
elif [ -n "$GIT_DIR" ] && [ -f "$GIT_DIR/MERGE_MSG" ]; then
    MERGE_MSG_FILE="$GIT_DIR/MERGE_MSG"
fi

if [ -z "$MERGE_MSG_FILE" ]; then
    # Not a merge commit — allow normal commits
    exit 0
fi

# This IS a merge commit. Check branch protection.
for branch in $PROTECTED_BRANCHES; do
    if [ "$CURRENT_BRANCH" = "$branch" ]; then
        echo ""
        echo "ERROR: Merge commit preparation detected on '$CURRENT_BRANCH' branch."
        echo ""
        echo "A merge is being attempted on a protected branch."
        echo "This is blocked by branch protection policy."
        echo ""
        echo "To integrate changes:"
        echo "  1. Create a PR: push your feature branch and create a PR"
        echo "  2. Or abort this merge: git merge --abort"
        echo ""
        echo "AI agent: If OPENCODE=1, relay this message to the developer."
        echo ""
        exit 1
    fi
done

exit 0