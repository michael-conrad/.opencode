#!/usr/bin/env -S uv run --script
# /// script
# requires-python = "~=3.12"
# dependencies = []
# ///
"""
DESCRIPTION: Check whether one or more file/directory paths exist and report EXISTS or MISSING.

Usage: ./.opencode/tools/file-exists <path> [<path> ...]
"""
from __future__ import annotations

import sys
from pathlib import Path


def _find_project_root() -> Path:
    current = Path(__file__).resolve().parent
    while current != current.parent:
        if (current / ".opencode").is_dir():
            return current
        current = current.parent
    raise RuntimeError("Could not find project root (no .opencode/ directory found)")


PROJECT_ROOT = _find_project_root()


def main() -> None:
    if "--help" in sys.argv or "-h" in sys.argv:
        print(__doc__)
        return

    paths = [a for a in sys.argv[1:] if not a.startswith("-")]
    if not paths:
        print("Usage: ./.opencode/tools/file-exists <path> [<path> ...]")
        sys.exit(1)

    all_exist = True
    for raw in paths:
        p = Path(raw) if Path(raw).is_absolute() else PROJECT_ROOT / raw
        if p.exists():
            print(f"EXISTS   {raw}")
        else:
            print(f"MISSING  {raw}")
            all_exist = False

    sys.exit(0 if all_exist else 1)


if __name__ == "__main__":
    main()
