#!/usr/bin/env -S uv run --script
# /// script
# requires-python = "~=3.12"
# dependencies = []
# ///
"""
DESCRIPTION: Guidelines tools dispatcher. Usage: ./.opencode/tools/guidelines <action> [args...]
Actions: read, load, list, show, search, edit
Example: ./.opencode/tools/guidelines search <term>
"""
from __future__ import annotations
import os
import subprocess
import sys
from pathlib import Path

BASE_DIR = Path(__file__).resolve().parent.parent.parent

ACTIONS = {
    "read": "guidelines-read",
    "load": "guidelines-read",
    "list": "guidelines-read",
    "show": "guidelines-show",
    "search": "guidelines-search",
    "edit": "guidelines-edit",
}


def _suggest_search_for_unknown_action(action: str, rest: list[str]) -> str | None:
    query_parts = [action, *rest]
    if not query_parts:
        return None
    if action.startswith("-"):
        return None
    query = " ".join(query_parts).strip()
    if not query:
        return None
    return f'Hint: did you mean `./.opencode/tools/guidelines search "{query}"`?'


def _run_action(script: Path, forwarded_args: list[str], summary: str) -> int:
    result = subprocess.run(
        ["uv", "run", str(script)] + forwarded_args,
        capture_output=True,
        text=True,
        env={**os.environ, "OPENCODE_TOOLS_DISPATCHER": "1"},
    )
    if result.stdout:
        sys.stdout.write(result.stdout)
    if result.stderr:
        sys.stderr.write(result.stderr)
    if result.returncode == 0 and not result.stdout and not result.stderr:
        print(summary)
    return result.returncode


def _get_description(script_path: Path) -> str:
    import re
    try:
        text = script_path.read_text()
        m = re.search(r'DESCRIPTION:\s*(.+)', text)
        return m.group(1).strip() if m else ""
    except Exception:
        return ""


def main() -> None:
    args = sys.argv[1:]
    if not args or args[0] in ("-h", "--help", "help"):
        print(__doc__)
        print("Available actions:")
        for action, script in ACTIONS.items():
            desc = _get_description(BASE_DIR / ".opencode" / "tools" / "impl" / script)
            print(f"  {action:<20} — {desc}" if desc else f"  {action:<20} → .opencode/tools/{script}")
        print(f"CWD: {os.getcwd()}")
        sys.exit(0)
    action = args[0]
    if action not in ACTIONS:
        print(f"Error: unknown action {action!r}. Available: {', '.join(ACTIONS)}", file=sys.stderr)
        suggestion = _suggest_search_for_unknown_action(action, args[1:])
        if suggestion:
            print(suggestion, file=sys.stderr)
        sys.exit(1)
    script = BASE_DIR / ".opencode" / "tools" / "impl" / ACTIONS[action]
    sys.exit(_run_action(script, args[1:], f"OK: .opencode/tools/guidelines {action} completed."))


if __name__ == "__main__":
    main()
