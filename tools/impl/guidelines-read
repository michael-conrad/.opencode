#!/usr/bin/env -S uv run --script
# /// script
# requires-python = "~=3.12"
# dependencies = []
# ///
"""
DESCRIPTION: Print the contents of a guideline file from .opencode/guidelines/.
Usage: ./.opencode/tools/guidelines read <filename>
Example: ./.opencode/tools/guidelines read 041
Note: Prefer 3-digit shorthand when available (for example `041` instead of full filename).
"""

from __future__ import annotations
import os as _os

if _os.environ.get("OPENCODE_TOOLS_DISPATCHER") != "1":
    print(
        "ERROR: This script must be run via its dispatcher (e.g. ./.opencode/tools/guidelines ...). "
        "Direct invocation is not permitted.",
        file=__import__("sys").stderr,
    )
    __import__("sys").exit(1)
import sys
from pathlib import Path

BASE_DIR = Path(__file__).resolve().parent.parent.parent.parent
GUIDELINES_DIR = BASE_DIR / ".opencode" / "guidelines"
SKILLS_DIR = BASE_DIR / ".opencode" / "skills"


def _resolve_guideline_path(name: str) -> Path | None:
    opencode_dir = BASE_DIR / ".opencode"
    candidates: list[Path] = [
        GUIDELINES_DIR / name,
        opencode_dir / name,
    ]
    if not name.endswith(".md"):
        candidates.extend(
            [
                GUIDELINES_DIR / f"{name}.md",
                opencode_dir / f"{name}.md",
            ]
        )

    for candidate in candidates:
        if candidate.exists() and candidate.is_file():
            return candidate

    if len(name) == 3 and name.isdigit():
        matches = sorted(
            path for path in GUIDELINES_DIR.glob(f"{name}*.md") if path.is_file()
        )
        if len(matches) == 1:
            return matches[0]
        if len(matches) > 1:
            print(
                f"Error: multiple guideline files found for prefix '{name}':",
                file=sys.stderr,
            )
            for path in matches:
                print(f"  {path.name}", file=sys.stderr)
            sys.exit(1)

    return None


def main() -> None:
    args = sys.argv[1:]
    if not args or args[0] in ("-h", "--help"):
        print(__doc__)
        files = sorted(GUIDELINES_DIR.glob("*.md"))
        if files:
            print("Available guideline files:")
            for f in files:
                print(f"  {f.name}")
        sys.exit(0)

    name = args[0]

    # Support skill files
    skill_relative: str | None = None
    if name.startswith("skills/"):
        skill_relative = name.removeprefix("skills/")
    elif name.startswith(".opencode/skills/"):
        skill_relative = name.removeprefix(".opencode/skills/")

    if skill_relative is not None:
        skill_candidate = SKILLS_DIR / skill_relative
        if skill_candidate.exists():
            print(skill_candidate.read_text())
            return

        # Try with SKILL.md suffix
        if not skill_relative.endswith(".md"):
            skill_candidate_md = SKILLS_DIR / skill_relative / "SKILL.md"
            if skill_candidate_md.exists():
                print(skill_candidate_md.read_text())
                return

        print(f"Error: skill file not found: {name}", file=sys.stderr)
        print(
            f"Available skills in {SKILLS_DIR.relative_to(BASE_DIR)}:", file=sys.stderr
        )
        for f in sorted(SKILLS_DIR.glob("*/SKILL.md")):
            print(f"  {f.parent.name}/SKILL.md", file=sys.stderr)
        sys.exit(1)

    path = _resolve_guideline_path(name)
    if path is None:
        print(f"Error: guideline file not found: {name}", file=sys.stderr)
        print(
            f"Available files in {GUIDELINES_DIR.relative_to(BASE_DIR)}:",
            file=sys.stderr,
        )
        for f in sorted(GUIDELINES_DIR.glob("*.md")):
            print(f"  {f.name}", file=sys.stderr)
        sys.exit(1)

    print(path.read_text())


if __name__ == "__main__":
    main()
