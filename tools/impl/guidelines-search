#!/usr/bin/env -S uv run --script
# /// script
# requires-python = "~=3.12"
# dependencies = []
# ///
"""
DESCRIPTION: Search guideline files using BM25 ranking with optional section blocks and context lines.
Usage: ./.opencode/tools/guidelines search <query> [--file <filename>] [--top N] [--section-names] [--section-blocks] [--context-lines N] [--minimal] [--surrounding N]
       ./.opencode/tools/guidelines search <filename.md> <query>
Note: Prefer 3-digit guideline filename shorthand when available (for example `041`).
      Searches recursively in subdirectories (git/, planning/, errors/, github/).
Flags:
  --minimal          Output match line only (no context)
  --surrounding N    Alias for --context-lines N
  --context-lines N  Set context lines (default: 1)
Examples: ./.opencode/tools/guidelines search "pyclbr"
          ./.opencode/tools/guidelines search "grep" --file 041
          ./.opencode/tools/guidelines search 041 "grep"
          ./.opencode/tools/guidelines search "notebook editing" --top 10
          ./.opencode/tools/guidelines search "pre-plan" --section-blocks
          ./.opencode/tools/guidelines search "branch" --minimal
          ./.opencode/tools/guidelines search "error" --surrounding 3
"""

from __future__ import annotations
import os as _os

if _os.environ.get("OPENCODE_TOOLS_DISPATCHER") != "1":
    print(
        "ERROR: This script must be run via its dispatcher (e.g. ./.opencode/tools/guidelines ...). "
        "Direct invocation is not permitted.",
        file=__import__("sys").stderr,
    )
    __import__("sys").exit(1)
import math
import re
import subprocess
import sys
from pathlib import Path

BASE_DIR = Path(__file__).resolve().parent
CDUP = subprocess.check_output(["git", "-C", str(BASE_DIR), "rev-parse", "--show-cdup"], text=True).strip()
PROJECT_ROOT = (BASE_DIR / CDUP).resolve()
GUIDELINES_DIR = PROJECT_ROOT / ".opencode" / "guidelines"

DEFAULT_TOP = 15


def _resolve_guideline_file(name: str) -> Path | None:
    # Try subdirectories first
    for subdir in ["git", "planning", "errors", "github"]:
        candidate = GUIDELINES_DIR / subdir / name
        if candidate.exists() and candidate.is_file():
            return candidate
        if not name.endswith(".md"):
            candidate_with_ext = GUIDELINES_DIR / subdir / f"{name}.md"
            if candidate_with_ext.exists() and candidate_with_ext.is_file():
                return candidate_with_ext

    # Try root level
    candidate = GUIDELINES_DIR / name
    if candidate.exists() and candidate.is_file():
        return candidate

    if not name.endswith(".md"):
        candidate_with_ext = GUIDELINES_DIR / f"{name}.md"
        if candidate_with_ext.exists() and candidate_with_ext.is_file():
            return candidate_with_ext

    if len(name) == 3 and name.isdigit():
        matches = sorted(
            path for path in GUIDELINES_DIR.glob(f"{name}*.md") if path.is_file()
        )
        if len(matches) == 1:
            return matches[0]
        if len(matches) > 1:
            print(
                f"Error: multiple guideline files found for prefix '{name}':",
                file=sys.stderr,
            )
            for path in matches:
                print(f"  {path.name}", file=sys.stderr)
            sys.exit(1)

    return None


def tokenize(text: str) -> list[str]:
    return re.findall(r"[a-z0-9_/']+", text.lower())


def get_topic(lines: list[str], lineno: int) -> str:
    """Return the nearest ## heading at or before lineno (1-based)."""
    topic = ""
    for i in range(lineno - 1, -1, -1):
        if lines[i].startswith("## "):
            topic = lines[i][3:].strip()
            break
        if lines[i].startswith("# ") and not topic:
            topic = lines[i][2:].strip()
    return topic or "(top)"


def get_section_bounds(lines: list[str], lineno: int) -> tuple[int, int, str]:
    """Return (start_line, end_line, heading_text) for nearest markdown section."""
    heading_idx = 0
    heading_text = "(top)"
    heading_level = 1

    for i in range(lineno - 1, -1, -1):
        line = lines[i].strip()
        if line.startswith("#"):
            level = len(line) - len(line.lstrip("#"))
            if line[level : level + 1] == " ":
                heading_idx = i
                heading_text = line[level + 1 :].strip() or "(top)"
                heading_level = level
                break

    end_idx = len(lines) - 1
    for i in range(heading_idx + 1, len(lines)):
        line = lines[i].strip()
        if line.startswith("#"):
            level = len(line) - len(line.lstrip("#"))
            if line[level : level + 1] == " " and level <= heading_level:
                end_idx = i - 1
                break

    return heading_idx + 1, end_idx + 1, heading_text


def build_corpus(files: list[Path]) -> tuple[list[dict], list[list[str]]]:
    """Return (docs metadata list, tokenized lines list).
    Each doc = one non-empty line with its file, lineno, topic, text.
    Handles both root-level files and subdirectory files.
    """
    docs: list[dict] = []
    token_lists: list[list[str]] = []
    for path in files:
        lines = path.read_text().splitlines()
        # Get relative path from GUIDELINES_DIR for display
        try:
            rel_path = path.relative_to(GUIDELINES_DIR)
            file_display = str(rel_path)
        except ValueError:
            file_display = path.name

        for i, line in enumerate(lines, start=1):
            stripped = line.strip()
            if not stripped:
                continue
            tokens = tokenize(stripped)
            if not tokens:
                continue
            docs.append(
                {
                    "file": file_display,
                    "lineno": i,
                    "topic": get_topic(lines, i),
                    "text": stripped,
                }
            )
            token_lists.append(tokens)
    return docs, token_lists


def bm25_search(
    query: str,
    docs: list[dict],
    token_lists: list[list[str]],
    top_n: int,
    k1: float = 1.5,
    b: float = 0.75,
) -> list[tuple[float, dict]]:
    """BM25 scoring for better phrase matching.

    Args:
        query: Search query string
        docs: List of document metadata
        token_lists: List of tokenized documents
        top_n: Maximum number of results
        k1: BM25 term frequency saturation parameter (default 1.5)
        b: BM25 length normalization parameter (default 0.75)

    Returns:
        List of (score, doc) tuples sorted by relevance
    """
    query_tokens = set(tokenize(query))
    if not query_tokens:
        return []

    n = len(token_lists)

    # Calculate document frequencies
    df: dict[str, int] = {}
    for tokens in token_lists:
        for t in set(tokens):
            df[t] = df.get(t, 0) + 1

    # Calculate average document length
    doc_lengths = [len(tokens) for tokens in token_lists]
    avg_doc_len = sum(doc_lengths) / len(doc_lengths) if doc_lengths else 1

    results: list[tuple[float, dict]] = []
    for doc, tokens in zip(docs, token_lists):
        doc_len = len(tokens)
        score = 0.0

        for qt in query_tokens:
            if qt not in df:
                continue

            # Term frequency in document
            tf = tokens.count(qt)
            if tf == 0:
                continue

            # IDF calculation
            idf = math.log((n - df[qt] + 0.5) / (df[qt] + 0.5) + 1)

            # BM25 scoring formula
            numerator = tf * (k1 + 1)
            denominator = tf + k1 * (1 - b + b * doc_len / avg_doc_len)
            score += idf * numerator / denominator

        if score > 0:
            results.append((score, doc))

    results.sort(key=lambda x: -x[0])
    return results[:top_n]


def main() -> None:
    args = sys.argv[1:]
    if not args or args[0] in ("-h", "--help"):
        print(__doc__)
        sys.exit(0)

    query_parts: list[str] = []
    file_filter: str | None = None
    top_n = DEFAULT_TOP
    show_section_names = False
    show_section_blocks = False
    context_lines = 1  # Changed from 0 to 1 as new default
    i = 0
    while i < len(args):
        if args[i] == "--file" and i + 1 < len(args):
            i += 1
            file_filter = args[i]
        elif args[i] == "--top" and i + 1 < len(args):
            i += 1
            try:
                top_n = int(args[i])
            except ValueError:
                print("Error: --top must be an integer.", file=sys.stderr)
                sys.exit(1)
        elif args[i] == "--section-names":
            show_section_names = True
        elif args[i] == "--section-blocks":
            show_section_blocks = True
        elif args[i] == "--minimal":
            context_lines = 0
        elif args[i] == "--surrounding" and i + 1 < len(args):
            i += 1
            try:
                context_lines = int(args[i])
                if context_lines < 0:
                    raise ValueError
            except ValueError:
                print(
                    "Error: --surrounding must be a non-negative integer.",
                    file=sys.stderr,
                )
                sys.exit(1)
        elif args[i] == "--context-lines" and i + 1 < len(args):
            i += 1
            try:
                context_lines = int(args[i])
                if context_lines < 0:
                    raise ValueError
            except ValueError:
                print(
                    "Error: --context-lines must be a non-negative integer.",
                    file=sys.stderr,
                )
                sys.exit(1)
        elif not args[i].startswith("--"):
            query_parts.append(args[i])
        i += 1

    # Auto-detect positional file argument when first token resolves to a guideline file.
    if query_parts and not file_filter:
        candidate = _resolve_guideline_file(query_parts[0])
        if candidate is not None:
            file_filter = query_parts[0]
            query_parts = query_parts[1:]

    query = " ".join(query_parts)
    if not query:
        print("Error: no search query specified.", file=sys.stderr)
        sys.exit(1)

    if file_filter:
        path = _resolve_guideline_file(file_filter)
        if path is None:
            print(f"Error: guideline file not found: {file_filter}", file=sys.stderr)
            sys.exit(1)
        files = [path]
    else:
        # Search recursively in subdirectories (git/, planning/, errors/, github/)
        files = sorted(GUIDELINES_DIR.glob("**/*.md"))

    docs, token_lists = build_corpus(files)
    results = bm25_search(query, docs, token_lists, top_n)

    if not results:
        print(f"No matches for '{query}'.")
        sys.exit(0)

    file_cache: dict[str, list[str]] = {}
    for score, doc in results:
        # Display relative path for subdirectory files
        file_display = doc["file"] if "/" not in doc["file"] else doc["file"]
        print(f"[{file_display}:{doc['lineno']}] ({doc['topic']})  {doc['text']}")
        if not (show_section_names or show_section_blocks or context_lines > 0):
            continue

        lines = file_cache.get(doc["file"])
        if lines is None:
            # Handle subdirectory paths
            file_path = GUIDELINES_DIR / doc["file"]
            if not file_path.exists():
                # Try subdirectories
                for subdir in ["git", "planning", "errors", "github"]:
                    candidate = GUIDELINES_DIR / subdir / doc["file"]
                    if candidate.exists():
                        file_path = candidate
                        break
            lines = file_path.read_text().splitlines()
            file_cache[doc["file"]] = lines

        start, end, heading = get_section_bounds(lines, doc["lineno"])
        if show_section_names:
            print(f"  section: {heading}")

        if show_section_blocks:
            print(f"  section-block [{start}-{end}]:")
            for line_no in range(start, end + 1):
                print(f"    [{line_no}] {lines[line_no - 1]}")

        if context_lines > 0:
            c_start = max(1, doc["lineno"] - context_lines)
            c_end = min(len(lines), doc["lineno"] + context_lines)
            print(f"  context [{c_start}-{c_end}]:")
            for line_no in range(c_start, c_end + 1):
                marker = ">" if line_no == doc["lineno"] else " "
                print(f"   {marker} [{line_no}] {lines[line_no - 1]}")


if __name__ == "__main__":
    main()
