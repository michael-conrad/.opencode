#!/usr/bin/env -S uv run --script
# /// script
# requires-python = "~=3.12"
# dependencies = []
# ///
"""
DESCRIPTION: Show guideline files with their brief summary header.
Usage: ./.opencode/tools/guidelines show [<file> ...]
Example: ./.opencode/tools/guidelines show 010 040
Note: Prefer 3-digit shorthand for guideline files when available (for example `041`).
"""

from __future__ import annotations
import os as _os

if _os.environ.get("OPENCODE_TOOLS_DISPATCHER") != "1":
    print(
        "ERROR: This script must be run via its dispatcher (e.g. ./.opencode/tools/guidelines ...). "
        "Direct invocation is not permitted.",
        file=__import__("sys").stderr,
    )
    __import__("sys").exit(1)
import sys
from pathlib import Path

BASE_DIR = Path(__file__).resolve().parent.parent.parent.parent
OPENCODE_DIR = BASE_DIR / ".opencode"
GUIDELINES_DIR = OPENCODE_DIR / "guidelines"


def _resolve_path(name: str) -> Path | None:
    if len(name) == 3 and name.isdigit():
        matches = sorted(
            path for path in GUIDELINES_DIR.glob(f"{name}*.md") if path.is_file()
        )
        if len(matches) == 1:
            return matches[0].resolve()
        if len(matches) > 1:
            print(
                f"Error: multiple guideline files found for prefix '{name}':",
                file=sys.stderr,
            )
            for path in matches:
                print(f"  {path.name}", file=sys.stderr)
            sys.exit(1)

    candidates = [
        BASE_DIR / name,
        OPENCODE_DIR / name,
        GUIDELINES_DIR / name,
    ]
    if not name.endswith(".md"):
        candidates.extend(
            [
                BASE_DIR / f"{name}.md",
                OPENCODE_DIR / f"{name}.md",
                GUIDELINES_DIR / f"{name}.md",
            ]
        )

    for candidate in candidates:
        if candidate.exists() and candidate.is_file():
            return candidate.resolve()
    return None


def _brief_header(path: Path) -> str:
    for raw_line in path.read_text().splitlines():
        line = raw_line.strip()
        if line.startswith("# "):
            return line
    return "(no level-1 header found)"


def _iter_default_files() -> list[Path]:
    return sorted(p.resolve() for p in GUIDELINES_DIR.glob("*.md") if p.is_file())


def main() -> None:
    args = sys.argv[1:]
    if args and args[0] in ("-h", "--help"):
        print(__doc__)
        sys.exit(0)

    paths: list[Path] = []
    if args:
        for name in args:
            path = _resolve_path(name)
            if path is None:
                print(f"Error: guideline file not found: {name}", file=sys.stderr)
                sys.exit(1)
            paths.append(path)
    else:
        paths = _iter_default_files()

    for path in paths:
        rel = path.relative_to(BASE_DIR)
        print(f"{rel}: {_brief_header(path)}")


if __name__ == "__main__":
    main()
