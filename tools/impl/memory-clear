#!/usr/bin/env -S uv run --script
# fmt: off
"exec" "uv" "run" "--script" "$0" "$@" # MUST GO BEFORE PEP 723 HEADER

# PEP 723 HEADER MUST BE AFTER BASH GUARD
# /// script
# requires-python = "~=3.12"
# dependencies = []
# ///

# fmt: on
__doc__ = """DESCRIPTION: Clear the Session State section of .opencode/memory.md.
Usage: ./.opencode/tools/memory clear
"""
import os as _os
if _os.environ.get("OPENCODE_TOOLS_DISPATCHER") != "1":
    print("ERROR: This script must be run via its dispatcher (e.g. ./.opencode/tools/memory ...). "
          "Direct invocation is not permitted.", file=__import__('sys').stderr)
    __import__('sys').exit(1)
import sys
from pathlib import Path

BASE_DIR = Path(__file__).resolve().parent

def _find_project_root(start: Path) -> Path:
    current = start.resolve()
    for _ in range(10):
        if (current / ".opencode").is_dir():
            return current
        if current.parent == current:
            break
        current = current.parent
    raise FileNotFoundError("Could not find project root directory")

PROJECT_ROOT = _find_project_root(BASE_DIR)
MEMORY_FILE = PROJECT_ROOT / ".opencode" / "memory.md"

SESSION_HEADER = "## Session State"

def main() -> None:
    if "--help" in sys.argv or "-h" in sys.argv:
        print(__doc__)
        sys.exit(0)
    if not MEMORY_FILE.exists():
        print(f"Memory file not found: {MEMORY_FILE}", file=sys.stderr)
        sys.exit(1)
    lines = MEMORY_FILE.read_text(encoding="utf-8").splitlines(keepends=True)
    in_session = False
    result = []
    for line in lines:
        if line.strip() == SESSION_HEADER:
            in_session = True
            result.append(line)
            continue
        if in_session:
            # Stop clearing at next ## section
            if line.startswith("## "):
                in_session = False
                result.append(line)
            # Skip bullet lines (session state entries)
            elif line.startswith("- "):
                continue
            else:
                result.append(line)
        else:
            result.append(line)
    MEMORY_FILE.write_text("".join(result), encoding="utf-8")
    print("Session State section cleared.")

if __name__ == "__main__":
    main()

