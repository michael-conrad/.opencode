#!/usr/bin/env -S uv run --script
"exec" "uv" "run" "--script" "$0" "$@" # MUST GO BEFORE PEP 723 HEADER

# PEP 723 HEADER MUST BE AFTER BASH GUARD
# /// script
# requires-python = "~=3.12"
# dependencies = ["pyyaml>=6.0"]
# ///

"""
DESCRIPTION: Guard completeness and disjointness per state machine — finds dead states and non-deterministic routing.
Usage: ./.opencode/tools/skildeck lint --analysis guards [--json] [--verbose]
"""

import json
import os as _os

import sys
import types
from dataclasses import dataclass, field, asdict
from pathlib import Path

IMPL_DIR = Path(__file__).resolve().parent
_path = IMPL_DIR
while _path.name != ".opencode":
    _path = _path.parent
BASE_DIR = _path.parent
DEFAULT_SCAN_DIR = BASE_DIR / ".opencode"

def _load_module(module_file: str):
    target = IMPL_DIR / module_file
    source = target.read_text()
    mod = types.ModuleType(module_file.replace("-", "_"))
    mod.__file__ = str(target)
    sys.modules[module_file.replace("-", "_")] = mod
    exec(compile(source, str(target), "exec"), mod.__dict__)
    return mod

@dataclass
class GuardFinding:
    state_machine_id: str
    state: str
    finding_type: str
    severity: str
    message: str
    guards: list[str] = field(default_factory=list)
    conflicting_pairs: list[tuple[str, str]] = field(default_factory=list)

    def to_dict(self) -> dict:
        d = asdict(self)
        d["conflicting_pairs"] = [f"{a} ⊗ {b}" for a, b in self.conflicting_pairs]
        return d

def _guards_can_overlap(g1: str, g2: str) -> bool:
    if g1 == g2:
        return True
    g1_parts = set(
        g1.replace(" AND ", "&")
        .replace(" and ", "&")
        .replace(" OR ", "|")
        .replace(" or ", "|")
        .split()
    )
    g2_parts = set(
        g2.replace(" AND ", "&")
        .replace(" and ", "&")
        .replace(" OR ", "|")
        .replace(" or ", "|")
        .split()
    )
    if g1_parts & g2_parts:
        return True
    if "true" in g1.lower() or "true" in g2.lower():
        return True
    return not g1_parts.isdisjoint(g2_parts)

def analyze_guards(scan_dir: Path, verbose: bool = False) -> list[GuardFinding]:
    extract_mod = _load_module("rules-extract")
    result = extract_mod.extract_yaml_blocks(scan_dir, verbose=verbose)

    state_machines = result.state_machines
    findings: list[GuardFinding] = []

    for sm in state_machines:
        state_transitions: dict[str, list] = {s: [] for s in sm.states}
        for t in sm.transitions:
            if t.from_state in state_transitions:
                state_transitions[t.from_state].append(t)
            else:
                state_transitions[t.from_state] = [t]
                findings.append(
                    GuardFinding(
                        state_machine_id=sm.id,
                        state=t.from_state,
                        finding_type="transition_from_undefined_state",
                        severity="HIGH",
                        message=f"Transition from '{t.from_state}' which is not in states list",
                        guards=[t.guard or "(no guard)"],
                        conflicting_pairs=[],
                    )
                )

        unreachable: set[str] = set(sm.states)
        for t in sm.transitions:
            unreachable.discard(t.to_state)
        unreachable.discard(sm.start_state)

        for state in sorted(unreachable):
            findings.append(
                GuardFinding(
                    state_machine_id=sm.id,
                    state=state,
                    finding_type="unreachable_state",
                    severity="MEDIUM",
                    message=f"State '{state}' is unreachable — no transition leads to it",
                    guards=[],
                    conflicting_pairs=[],
                )
            )

        for state, transitions in state_transitions.items():
            if state == sm.states[-1] if sm.states else "":
                continue

            transition_guards = [t.guard or "(no guard)" for t in transitions]

            if not transitions and state != (sm.states[-1] if sm.states else ""):
                findings.append(
                    GuardFinding(
                        state_machine_id=sm.id,
                        state=state,
                        finding_type="dead_state",
                        severity="CRITICAL",
                        message=f"State '{state}' has no outgoing transitions (dead state — no guard can fire)",
                        guards=[],
                        conflicting_pairs=[],
                    )
                )
                continue

            if len(transitions) > 0:
                has_catch_all = any(
                    "true" in g.lower() or g == "(no guard)" for g in transition_guards
                )
                if (
                    not has_catch_all
                    and len(transition_guards)
                    < len([s for s in sm.states if s != state]) // 2 + 1
                ):
                    findings.append(
                        GuardFinding(
                            state_machine_id=sm.id,
                            state=state,
                            finding_type="completeness_gap",
                            severity="HIGH",
                            message=f"State '{state}' guards may not cover all cases — no catch-all guard and only {len(transition_guards)} transition(s)",
                            guards=transition_guards,
                            conflicting_pairs=[],
                        )
                    )

            for i in range(len(transitions)):
                for j in range(i + 1, len(transitions)):
                    g1 = transitions[i].guard or "(no guard)"
                    g2 = transitions[j].guard or "(no guard)"
                    if _guards_can_overlap(g1, g2):
                        findings.append(
                            GuardFinding(
                                state_machine_id=sm.id,
                                state=state,
                                finding_type="non_deterministic",
                                severity="HIGH",
                                message=f"State '{state}' has overlapping guards: '{g1}' and '{g2}' — could fire non-deterministically",
                                guards=[g1, g2],
                                conflicting_pairs=[(g1, g2)],
                            )
                        )

        reachable_from_start: set[str] = set()
        queue = [sm.start_state]
        while queue:
            current = queue.pop(0)
            if current in reachable_from_start:
                continue
            reachable_from_start.add(current)
            for t in state_transitions.get(current, []):
                if t.to_state not in reachable_from_start:
                    queue.append(t.to_state)

        for state in sm.states:
            if state not in reachable_from_start and state != sm.start_state:
                findings.append(
                    GuardFinding(
                        state_machine_id=sm.id,
                        state=state,
                        finding_type="unreachable_from_start",
                        severity="MEDIUM",
                        message=f"State '{state}' is not reachable from start state '{sm.start_state}'",
                        guards=[],
                        conflicting_pairs=[],
                    )
                )

    return findings

def main() -> None:
    if _os.environ.get("OPENCODE_TOOLS_DISPATCHER") != "1":
        print(
            "ERROR: This script must be run via its dispatcher. Direct invocation is not permitted.",
            file=sys.stderr,
        )
        sys.exit(1)

    import argparse

    parser = argparse.ArgumentParser(
        description="Guard completeness and disjointness analysis"
    )
    parser.add_argument("--dir", type=str, default=str(DEFAULT_SCAN_DIR))
    parser.add_argument("--verbose", action="store_true")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()

    scan_dir = Path(args.dir)
    if not scan_dir.exists():
        print(f"Error: directory not found: {scan_dir}", file=sys.stderr)
        sys.exit(1)

    findings = analyze_guards(scan_dir, verbose=args.verbose)

    if args.json:
        print(json.dumps([f.to_dict() for f in findings], indent=2))
    else:
        severity_order = {"CRITICAL": 0, "HIGH": 1, "MEDIUM": 2, "LOW": 3}
        findings.sort(key=lambda f: severity_order.get(f.severity, 4))
        print(
            f"Guard Analysis — {len(findings)} findings across {len(set(f.state_machine_id for f in findings))} state machine(s)"
        )
        by_sm: dict[str, list[GuardFinding]] = {}
        for f in findings:
            by_sm.setdefault(f.state_machine_id, []).append(f)
        for sm_id, sm_findings in sorted(by_sm.items()):
            print(f"\nState Machine: {sm_id}")
            for item in sm_findings:
                print(f"  [{item.severity}] {item.finding_type} @ {item.state}")
                print(f"    {item.message}")
                if item.guards:
                    print(f"    guards: {', '.join(item.guards)}")

if __name__ == "__main__":
    main()
