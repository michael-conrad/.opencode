"""
DESCRIPTION: Full symbolic analysis across all yaml+symbolic blocks including v2.0 sections.
Usage: ./.opencode/tools/skildeck analyze [--dir PATH] [--json] [--verbose]
"""

from __future__ import annotations

import json
import os as _os
import sys
import types
from pathlib import Path

# Find skills directory without git assumptions
IMPL_DIR = Path(__file__).resolve().parent
SKILLS_DIR = None
for parent in [IMPL_DIR] + list(IMPL_DIR.parents):
    candidate = parent / "skills"
    if candidate.exists() and candidate.is_dir():
        SKILLS_DIR = candidate
        break

if SKILLS_DIR is None:
    if _os.environ.get("SKILDECK_SKILLS_DIR"):
        SKILLS_DIR = Path(_os.environ["SKILDECK_SKILLS_DIR"])
    else:
        raise RuntimeError(f"Cannot find skills/ directory. Searched up from {IMPL_DIR}. Set SKILDECK_SKILLS_DIR env var to override.")

DEFAULT_SCAN_DIR = SKILLS_DIR
DEFAULT_OUTPUT_DIR = Path("./tmp")


def _load_module(module_file: str):
    source = (IMPL_DIR.parent / module_file).read_text()
    mod = types.ModuleType(module_file.replace("-", "_"))
    mod.__file__ = str(IMPL_DIR.parent / module_file)
    sys.modules[module_file.replace("-", "_")] = mod
    exec(compile(source, str(IMPL_DIR.parent / module_file), "exec"), mod.__dict__)
    return mod


def main() -> None:
    if _os.environ.get("OPENCODE_TOOLS_DISPATCHER") != "1":
        print(
            "ERROR: This script must be run via its dispatcher. Direct invocation is not permitted.",
            file=sys.stderr,
        )
        sys.exit(1)

    import argparse

    parser = argparse.ArgumentParser(description="Full symbolic analysis (v1.0 + v2.0)")
    parser.add_argument("--dir", type=str, default=str(DEFAULT_SCAN_DIR))
    parser.add_argument("--output", type=str, default=str(DEFAULT_OUTPUT_DIR))
    parser.add_argument("--verbose", action="store_true")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()

    scan_dir = Path(args.dir)
    output_dir = Path(args.output)
    output_dir.mkdir(parents=True, exist_ok=True)

    extract_mod = _load_module("sym-extract")
    result = extract_mod.extract_yaml_blocks(scan_dir, verbose=args.verbose)

    all_results = {
        "extract": result.to_dict(),
        "lint": [],
        "gates": [],
        "pipeline": [],
    }

    print(
        f"\nExtracted: {len(result.rules)} rules, {len(result.state_machines)} state machines"
    )
    print(f"  Tasks (v2.0):             {len(result.tasks)}")
    print(f"  Decomposition (v2.0):     {len(result.decomposition)}")
    print(f"  Gates (v2.0):             {len(result.gates)}")
    print(f"  Evidence artifacts (v2.0): {len(result.evidence_artifacts)}")

    for t in result.tasks:
        print(f"  TASK[{t.id}] skill={t.skill} pre={t.preconditions}")
    for g in result.gates:
        print(f"  GATE[{g.id}] {g.condition} critical={g.critical_violation}")
    for ea in result.evidence_artifacts:
        print(f"  EVIDENCE[{ea.name}] type={ea.type} verify={ea.verification}")

    result_path = output_dir / "skildeck-analysis.json"
    with open(result_path, "w") as f:
        json.dump(all_results, f, indent=2, default=str)
    print(f"\nResults written to {result_path}")

    if args.json:
        print(json.dumps(all_results, indent=2, default=str))


if __name__ == "__main__":
    main()
