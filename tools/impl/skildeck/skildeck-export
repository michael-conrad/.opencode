# fmt: on
"""
DESCRIPTION: Export symbolic models to static formats (mermaid, dot, html).
Usage: ./.opencode/tools/skildeck export --format mermaid|dot|html [--dir PATH] [--output PATH]
"""

import json
import os as _os
import sys
import types
from pathlib import Path

# Find skills directory without git assumptions
IMPL_DIR = Path(__file__).resolve().parent
SKILLS_DIR = None
for parent in [IMPL_DIR] + list(IMPL_DIR.parents):
    candidate = parent / "skills"
    if candidate.exists() and candidate.is_dir():
        SKILLS_DIR = candidate
        break

if SKILLS_DIR is None:
    if _os.environ.get("SKILDECK_SKILLS_DIR"):
        SKILLS_DIR = Path(_os.environ["SKILDECK_SKILLS_DIR"])
    else:
        raise RuntimeError(f"Cannot find skills/ directory. Searched up from {IMPL_DIR}. Set SKILDECK_SKILLS_DIR env var to override.")

DEFAULT_SCAN_DIR = SKILLS_DIR
DEFAULT_OUTPUT_DIR = Path("./tmp")

def _load_module(module_file: str):
    target = IMPL_DIR.parent / module_file
    source = target.read_text()
    mod = types.ModuleType(module_file.replace("-", "_"))
    mod.__file__ = str(target)
    sys.modules[module_file.replace("-", "_")] = mod
    exec(compile(source, str(target), "exec"), mod.__dict__)
    return mod

def _export_mermaid(rules, state_machines, tasks, gates) -> str:
    lines = ["graph TD"]
    for rule in rules:
        rid = rule.id.replace("-", "_")
        label = rule.title.replace('"', "'")[:60]
        lines.append(f'    {rid}["{label}"]')

    for rule in rules:
        for req in rule.requires:
            req_id = req.replace("-", "_")
            lines.append(f"    {req_id} --> {rule.id.replace('-', '_')}")

    for rule in rules:
        for trig in rule.triggers:
            trig_name = trig.replace("-", "_")
            rid = rule.id.replace("-", "_")
            lines.append(f"    {rid} -.->|triggers| {trig_name}")

    for gate in gates:
        gid = gate.id.replace("-", "_")
        label = gate.condition.replace('"', "'")[:50]
        color = (
            "stroke:red,stroke-width:3px"
            if gate.critical_violation
            else "stroke:orange,stroke-width:2px"
        )
        lines.append(f'    {gid}{{"GATE: {label}"}}')
        lines.append(f"    style {gid} {color}")

    for task in tasks:
        tid = task.id.replace("-", "_")
        label = f"{task.skill}/{task.id}"
        lines.append(f'    {tid}{{"TASK: {label}"}}')

    return "\n".join(lines)

def _export_dot(rules, state_machines, tasks, gates) -> str:
    lines = ["digraph symbolic {"]
    lines.append("    rankdir=TB;")
    lines.append("    node [shape=box];")

    for rule in rules:
        rid = rule.id.replace("-", "_")
        label = rule.title.replace('"', '\\"')[:60]
        lines.append(f'    {rid} [label="{label}"];')

    for rule in rules:
        for req in rule.requires:
            req_id = req.replace("-", "_")
            lines.append(f"    {req_id} -> {rule.id.replace('-', '_')};")

    for rule in rules:
        for trig in rule.triggers:
            trig_name = trig.replace("-", "_")
            rid = rule.id.replace("-", "_")
            lines.append(f'    {rid} -> {trig_name} [style=dashed, label="triggers"];')

    for gate in gates:
        gid = gate.id.replace("-", "_")
        label = gate.condition.replace('"', '\\"')[:50]
        color = "red" if gate.critical_violation else "orange"
        lines.append(f'    {gid} [label="GATE: {label}", color={color}];')

    for task in tasks:
        tid = task.id.replace("-", "_")
        label = f"{task.skill}/{task.id}".replace('"', '\\"')
        lines.append(f'    {tid} [label="TASK: {label}", shape=ellipse];')

    lines.append("}")
    return "\n".join(lines)

def _export_html(
    rules, state_machines, tasks, gates, evidence_artifacts, decomposition
) -> str:
    data = {
        "rules": [r.to_dict() for r in rules],
        "state_machines": [sm.to_dict() for sm in state_machines],
        "tasks": [t.to_dict() for t in tasks],
        "gates": [g.to_dict() for g in gates],
        "evidence_artifacts": [ea.to_dict() for ea in evidence_artifacts],
        "decomposition": [d.to_dict() for d in decomposition],
    }
    json_data = json.dumps(data, indent=2, default=str)

    return f"""<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Skill Deck Report</title>
<style>
body {{ font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; margin: 2rem; background: #1a1a2e; color: #e0e0e0; }}
h1 {{ color: #7c4dff; }} h2 {{ color: #b388ff; }} h3 {{ color: #ea80fc; }}
.section {{ margin: 1.5rem 0; padding: 1rem; background: #16213e; border-radius: 8px; }}
.rule, .gate, .task, .evidence {{ padding: 0.75rem; margin: 0.5rem 0; background: #0f3460; border-radius: 4px; border-left: 4px solid #7c4dff; }}
.gate.critical {{ border-left-color: #ff1744; }} .gate {{ border-left-color: #ff9100; }}
.task {{ border-left-color: #00e676; }} .evidence {{ border-left-color: #40c4ff; }}
dl {{ display: grid; grid-template-columns: auto 1fr; gap: 0.25rem 1rem; }}
dt {{ font-weight: 600; color: #b388ff; }}
pre {{ overflow-x: auto; background: #0a0a1a; padding: 1rem; border-radius: 4px; }}
</style>
</head>
<body>
<h1>Skill Deck Report</h1>
<div class="section"><h2>Summary</h2>
<dl><dt>Rules:</dt><dd>{len(rules)}</dd><dt>State Machines:</dt><dd>{len(state_machines)}</dd>
<dt>Tasks:</dt><dd>{len(tasks)}</dd><dt>Gates:</dt><dd>{len(gates)}</dd>
<dt>Evidence Artifacts:</dt><dd>{len(evidence_artifacts)}</dd><dt>Decomposition:</dt><dd>{len(decomposition)}</dd></dl></div>
<div class="section"><h2>Gates</h2>
{"".join(f'<div class="gate {"critical" if g.critical_violation else ""}"><h3>{g.id}</h3><dl><dt>Condition:</dt><dd>{g.condition}</dd><dt>On Fail:</dt><dd>{g.on_fail or "N/A"}</dd><dt>Critical:</dt><dd>{g.critical_violation}</dd></dl></div>' for g in gates)}
</div>
<div class="section"><h2>Tasks</h2>
{"".join(f'<div class="task"><h3>{t.id}</h3><dl><dt>Skill:</dt><dd>{t.skill}</dd><dt>Preconditions:</dt><dd>{", ".join(t.preconditions) or "none"}</dd><dt>Postconditions:</dt><dd>{", ".join(t.postconditions) or "none"}</dd><dt>Mandatory:</dt><dd>{t.mandatory}</dd></dl></div>' for t in tasks)}
</div>
<div class="section"><h2>Evidence Artifacts</h2>
{"".join(f'<div class="evidence"><h3>{ea.name}</h3><dl><dt>Type:</dt><dd>{ea.type}</dd><dt>Verification:</dt><dd>{ea.verification}</dd></dl></div>' for ea in evidence_artifacts)}
</div>
<div class="section"><h2>Raw Data</h2><pre id="raw-data"></pre></div>
<script>document.getElementById('raw-data').textContent = {json.dumps(json_data)};</script>
</body></html>"""

def main() -> None:
    if _os.environ.get("OPENCODE_TOOLS_DISPATCHER") != "1":
        print(
            "ERROR: This script must be run via its dispatcher. Direct invocation is not permitted.",
            file=sys.stderr,
        )
        sys.exit(1)

    import argparse

    parser = argparse.ArgumentParser(
        description="Export symbolic models to static formats"
    )
    parser.add_argument(
        "--format",
        type=str,
        choices=["mermaid", "dot", "html"],
        required=True,
        help="Output format",
    )
    parser.add_argument("--dir", type=str, default=str(DEFAULT_SCAN_DIR))
    parser.add_argument("--output", type=str, default=str(DEFAULT_OUTPUT_DIR))
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()

    scan_dir = Path(args.dir)
    output_dir = Path(args.output)
    output_dir.mkdir(parents=True, exist_ok=True)

    extract_mod = _load_module("sym-extract")
    result = extract_mod.extract_yaml_blocks(scan_dir)

    fmt = args.format
    if fmt == "mermaid":
        output = _export_mermaid(
            result.rules, result.state_machines, result.tasks, result.gates
        )
        out_path = output_dir / "skildeck-pipeline.mmd"
    elif fmt == "dot":
        output = _export_dot(
            result.rules, result.state_machines, result.tasks, result.gates
        )
        out_path = output_dir / "skildeck-pipeline.dot"
    elif fmt == "html":
        output = _export_html(
            result.rules,
            result.state_machines,
            result.tasks,
            result.gates,
            result.evidence_artifacts,
            result.decomposition,
        )
        out_path = output_dir / "skildeck-report.html"
    else:
        print(f"Error: unknown format {fmt!r}", file=sys.stderr)
        sys.exit(1)

    out_path.write_text(output)
    print(f"Exported {fmt} to {out_path}")

    if args.json:
        print(
            json.dumps(
                {
                    "format": fmt,
                    "output_path": str(out_path),
                    "rules": len(result.rules),
                    "gates": len(result.gates),
                    "tasks": len(result.tasks),
                },
                indent=2,
            )
        )

if __name__ == "__main__":
    main()

