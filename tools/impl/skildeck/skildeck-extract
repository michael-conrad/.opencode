"""
DESCRIPTION: Extract symbolic models from all files or a single skill. Outputs structured JSON.
Usage: ./.opencode/tools/skildeck extract [--dir PATH] [--skill NAME] [--json] [--verbose]
"""

from __future__ import annotations

import json
import os as _os
import sys
import types
from pathlib import Path

# Find skills directory without git assumptions
IMPL_DIR = Path(__file__).resolve().parent
SKILLS_DIR = None
for parent in [IMPL_DIR] + list(IMPL_DIR.parents):
    candidate = parent / "skills"
    if candidate.exists() and candidate.is_dir():
        SKILLS_DIR = candidate
        break

if SKILLS_DIR is None:
    if _os.environ.get("SKILDECK_SKILLS_DIR"):
        SKILLS_DIR = Path(_os.environ["SKILDECK_SKILLS_DIR"])
    else:
        raise RuntimeError(f"Cannot find skills/ directory. Searched up from {IMPL_DIR}. Set SKILDECK_SKILLS_DIR env var to override.")

DEFAULT_SCAN_DIR = SKILLS_DIR


def _load_module(module_file: str):
    target = IMPL_DIR.parent / module_file
    source = target.read_text()
    mod = types.ModuleType(module_file.replace("-", "_"))
    mod.__file__ = str(target)
    sys.modules[module_file.replace("-", "_")] = mod
    exec(compile(source, str(target), "exec"), mod.__dict__)
    return mod


def main() -> None:
    if _os.environ.get("OPENCODE_TOOLS_DISPATCHER") != "1":
        print(
            "ERROR: This script must be run via its dispatcher. Direct invocation is not permitted.",
            file=sys.stderr,
        )
        sys.exit(1)

    import argparse

    parser = argparse.ArgumentParser(
        description="Extract symbolic models from yaml+symbolic blocks"
    )
    parser.add_argument("--dir", type=str, default=str(DEFAULT_SCAN_DIR))
    parser.add_argument("--skill", type=str, default="", help="Filter by skill name")
    parser.add_argument("--verbose", action="store_true")
    parser.add_argument("--json", action="store_true", help="Output as JSON")
    args = parser.parse_args()

    scan_dir = Path(args.dir)
    if not scan_dir.exists():
        print(f"Error: directory not found: {scan_dir}", file=sys.stderr)
        sys.exit(1)

    extract_mod = _load_module("sym-extract")
    result = extract_mod.extract_yaml_blocks(scan_dir, verbose=args.verbose)

    if args.skill:
        skill_lower = args.skill.lower()
        result.rules = [
            r
            for r in result.rules
            if skill_lower in r.source.lower() or skill_lower in r.id.lower()
        ]
        result.state_machines = [
            sm for sm in result.state_machines if skill_lower in sm.id.lower()
        ]
        result.tasks = [
            t
            for t in result.tasks
            if skill_lower in t.skill.lower() or skill_lower in t.source.lower()
        ]
        result.gates = [
            g
            for g in result.gates
            if skill_lower in g.id.lower() or skill_lower in g.source.lower()
        ]
        result.decomposition = [
            d
            for d in result.decomposition
            if skill_lower in d.skill.lower() or skill_lower in d.source.lower()
        ]
        result.evidence_artifacts = [
            ea for ea in result.evidence_artifacts if skill_lower in ea.source.lower()
        ]

    if args.json:
        print(json.dumps(result.to_dict(), indent=2))
    else:
        print(f"Skill: {args.skill or 'ALL'}")
        print(f"  Rules:            {len(result.rules)}")
        print(f"  State machines:   {len(result.state_machines)}")
        print(f"  Tasks:            {len(result.tasks)}")
        print(f"  Decomposition:    {len(result.decomposition)}")
        print(f"  Gates:            {len(result.gates)}")
        print(f"  Evidence artifacts: {len(result.evidence_artifacts)}")
        print(f"  Files scanned:    {result.files_scanned}")
        print(f"  Blocks found:     {result.blocks_found}")
        for r in result.rules:
            print(f"\n  [{r.id}] {r.title}")
            if r.conditions_all:
                print(f"    conditions (all): {r.conditions_all}")
            if r.conditions_any:
                print(f"    conditions (any): {r.conditions_any}")
            print(f"    actions: {r.actions}")
            if r.requires:
                print(f"    requires: {r.requires}")
            if r.triggers:
                print(f"    triggers: {r.triggers}")
            print(f"    source: {r.source}")
        for g in result.gates:
            print(f"\n  GATE[{g.id}] {g.condition}")
            print(
                f"    on_fail: {g.on_fail or 'N/A'}  critical: {g.critical_violation}"
            )
        for t in result.tasks:
            print(f"\n  TASK[{t.id}] skill={t.skill}")
            print(f"    pre:  {t.preconditions}")
            print(f"    post: {t.postconditions}")
            print(f"    mandatory: {t.mandatory}")
        for ea in result.evidence_artifacts:
            print(f"\n  EVIDENCE[{ea.name}] type={ea.type}")
            print(f"    verification: {ea.verification}")


if __name__ == "__main__":
    main()
