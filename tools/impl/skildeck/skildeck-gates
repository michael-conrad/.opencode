#!/usr/bin/env -S uv run --script
# /// script
# requires-python = "~=3.12"
# dependencies = ["pyyaml>=6.0"]
# ///
"""
DESCRIPTION: Pipeline view with gate conditions. Show gates and their evidence requirements.
Usage: ./.opencode/tools/skildeck gates [--scope SCOPE] [--at TASK] [--json]
"""

from __future__ import annotations

import json
import os as _os
import subprocess
import sys
import types
from pathlib import Path

IMPL_DIR = Path(__file__).resolve().parent
CDUP = subprocess.check_output(
    ["git", "-C", str(IMPL_DIR), "rev-parse", "--show-cdup"], text=True
).strip()
BASE_DIR = (IMPL_DIR / CDUP).resolve()
DEFAULT_SCAN_DIR = BASE_DIR / ".opencode"


def _load_module(module_file: str):
    target = IMPL_DIR.parent / module_file
    source = target.read_text()
    mod = types.ModuleType(module_file.replace("-", "_"))
    mod.__file__ = str(target)
    sys.modules[module_file.replace("-", "_")] = mod
    exec(compile(source, str(target), "exec"), mod.__dict__)
    return mod


def main() -> None:
    if _os.environ.get("OPENCODE_TOOLS_DISPATCHER") != "1":
        print(
            "ERROR: This script must be run via its dispatcher. Direct invocation is not permitted.",
            file=sys.stderr,
        )
        sys.exit(1)

    import argparse

    parser = argparse.ArgumentParser(description="Pipeline view with gate conditions")
    parser.add_argument("--dir", type=str, default=str(DEFAULT_SCAN_DIR))
    parser.add_argument(
        "--scope", type=str, default="", help="Filter by scope (e.g., 'approval-gate')"
    )
    parser.add_argument(
        "--at",
        type=str,
        default="",
        help="Show evidence requirements at a specific task/gate",
    )
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()

    scan_dir = Path(args.dir)
    if not scan_dir.exists():
        print(f"Error: directory not found: {scan_dir}", file=sys.stderr)
        sys.exit(1)

    extract_mod = _load_module("sym-extract")
    result = extract_mod.extract_yaml_blocks(scan_dir)

    gates = result.gates
    tasks = result.tasks
    decomposition = result.decomposition
    evidence_artifacts = result.evidence_artifacts

    if args.scope:
        gates = [
            g
            for g in gates
            if args.scope.lower() in g.source.lower()
            or args.scope.lower() in g.id.lower()
        ]
        tasks = [
            t
            for t in tasks
            if args.scope.lower() in t.skill.lower()
            or args.scope.lower() in t.source.lower()
        ]
        decomposition = [
            d
            for d in decomposition
            if args.scope.lower() in d.skill.lower()
            or args.scope.lower() in d.source.lower()
        ]
        evidence_artifacts = [
            ea for ea in evidence_artifacts if args.scope.lower() in ea.source.lower()
        ]

    if args.at:
        task_match = [t for t in tasks if args.at.lower() in t.id.lower()]
        gate_at = [g for g in gates if args.at.lower() in g.id.lower()]
        ev_at = [ea for ea in evidence_artifacts if args.at.lower() in ea.name.lower()]

        if args.json:
            print(
                json.dumps(
                    {
                        "tasks_at": [t.to_dict() for t in task_match],
                        "gates_at": [g.to_dict() for g in gate_at],
                        "evidence_at": [ea.to_dict() for ea in ev_at],
                    },
                    indent=2,
                )
            )
        else:
            print(f"Evidence requirements at '{args.at}':")
            print(f"\n  Tasks ({len(task_match)}):")
            for t in task_match:
                print(f"    [{t.id}] skill={t.skill}")
                print(f"      preconditions:  {t.preconditions}")
                print(f"      postconditions: {t.postconditions}")
                print(
                    f"      mandatory: {t.mandatory}  bypass_violation: {t.bypass_violation or 'N/A'}"
                )
            print(f"\n  Gates ({len(gate_at)}):")
            for g in gate_at:
                print(f"    [{g.id}] {g.condition}")
                print(
                    f"      on_fail: {g.on_fail or 'N/A'}  critical_violation: {g.critical_violation}"
                )
            print(f"\n  Evidence Artifacts ({len(ev_at)}):")
            for ea in ev_at:
                print(f"    [{ea.name}] type={ea.type} verification={ea.verification}")
        return

    pipeline = []
    for d in decomposition:
        pipeline.append(f"  {d.type}: {d.skill}/{d.task} (mandatory={d.mandatory})")

    if args.json:
        print(
            json.dumps(
                {
                    "gates": [g.to_dict() for g in gates],
                    "tasks": [t.to_dict() for t in tasks],
                    "decomposition": [d.to_dict() for d in decomposition],
                    "evidence_artifacts": [ea.to_dict() for ea in evidence_artifacts],
                    "pipeline": pipeline,
                },
                indent=2,
            )
        )
    else:
        print(f"Pipeline View ({len(gates)} gates, {len(tasks)} tasks)")
        print(f"Scope filter: {args.scope or 'none'}")
        print()
        print("Decomposition:")
        if pipeline:
            for p in pipeline:
                print(p)
        else:
            print("  (no decomposition entries)")

        print(f"\nGates ({len(gates)}):")
        for g in gates:
            cv = " CRITICAL" if g.critical_violation else ""
            print(f"  [{g.id}] {g.condition}{cv}")
            if g.on_fail:
                print(f"    on_fail: {g.on_fail}")

        print(f"\nTasks ({len(tasks)}):")
        for t in tasks:
            print(f"  [{t.id}] skill={t.skill} mandatory={t.mandatory}")
            if t.preconditions:
                print(f"    pre:  {t.preconditions}")
            if t.postconditions:
                print(f"    post: {t.postconditions}")

        print(f"\nEvidence Artifacts ({len(evidence_artifacts)}):")
        for ea in evidence_artifacts:
            print(f"  [{ea.name}] type={ea.type} verify={ea.verification}")


if __name__ == "__main__":
    main()
