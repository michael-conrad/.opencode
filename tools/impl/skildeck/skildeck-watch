"""
DESCRIPTION: Watch work-state and auto-regenerate HTML report. Polls for changes.
Usage: ./.opencode/tools/skildeck watch [--dir PATH] [--output PATH] [--interval SECONDS]
"""

import hashlib
import os as _os
import sys
import time
import types
from pathlib import Path

# Find skills directory without git assumptions
IMPL_DIR = Path(__file__).resolve().parent
SKILLS_DIR = None
for parent in [IMPL_DIR] + list(IMPL_DIR.parents):
    candidate = parent / "skills"
    if candidate.exists() and candidate.is_dir():
        SKILLS_DIR = candidate
        break

if SKILLS_DIR is None:
    if _os.environ.get("SKILDECK_SKILLS_DIR"):
        SKILLS_DIR = Path(_os.environ["SKILDECK_SKILLS_DIR"])
    else:
        raise RuntimeError(f"Cannot find skills/ directory. Searched up from {IMPL_DIR}. Set SKILDECK_SKILLS_DIR env var to override.")

DEFAULT_SCAN_DIR = SKILLS_DIR
DEFAULT_OUTPUT_DIR = Path("./tmp")
DEFAULT_INTERVAL = 30


def _load_module(module_file: str):
    target = IMPL_DIR.parent / module_file
    source = target.read_text()
    mod = types.ModuleType(module_file.replace("-", "_"))
    mod.__file__ = str(target)
    sys.modules[module_file.replace("-", "_")] = mod
    exec(compile(source, str(target), "exec"), mod.__dict__)
    return mod


def _load_impl(module_name: str):
    target = IMPL_DIR / module_name
    source = target.read_text()
    mod = types.ModuleType(module_name.replace("-", "_"))
    mod.__file__ = str(target)
    sys.modules[module_name.replace("-", "_")] = mod
    exec(compile(source, str(target), "exec"), mod.__dict__)
    return mod


def _hash_dir(scan_dir: Path) -> str:
    h = hashlib.sha256()
    md_files = sorted(scan_dir.rglob("*.md"))
    for f in md_files:
        try:
            h.update(f.read_bytes())
        except Exception:
            pass
    return h.hexdigest()[:16]


def main() -> None:
    if _os.environ.get("OPENCODE_TOOLS_DISPATCHER") != "1":
        print(
            "ERROR: This script must be run via its dispatcher. Direct invocation is not permitted.",
            file=sys.stderr,
        )
        sys.exit(1)

    import argparse

    parser = argparse.ArgumentParser(
        description="Watch work-state and auto-regenerate HTML report"
    )
    parser.add_argument("--dir", type=str, default=str(DEFAULT_SCAN_DIR))
    parser.add_argument("--output", type=str, default=str(DEFAULT_OUTPUT_DIR))
    parser.add_argument(
        "--interval",
        type=int,
        default=DEFAULT_INTERVAL,
        help="Polling interval in seconds",
    )
    args = parser.parse_args()

    scan_dir = Path(args.dir)
    output_dir = Path(args.output)
    output_dir.mkdir(parents=True, exist_ok=True)

    export_mod = _load_impl("skildeck-export")
    last_hash = ""

    print(f"Watching {scan_dir} (interval: {args.interval}s). Press Ctrl+C to stop.")
    try:
        while True:
            current_hash = _hash_dir(scan_dir)
            if current_hash != last_hash:
                print(f"Change detected (hash: {current_hash}), regenerating...")
                try:
                    extract_mod = _load_module("sym-extract")
                    result = extract_mod.extract_yaml_blocks(scan_dir)
                    html_output = export_mod._export_html(
                        result.rules,
                        result.state_machines,
                        result.tasks,
                        result.gates,
                        result.evidence_artifacts,
                        result.decomposition,
                    )
                    out_path = output_dir / "skildeck-report.html"
                    out_path.write_text(html_output)
                    print(f"  Regenerated: {out_path}")
                except Exception as e:
                    print(f"  Error regenerating: {e}", file=sys.stderr)
                last_hash = current_hash
            time.sleep(args.interval)
    except KeyboardInterrupt:
        print("\nWatch stopped.")


if __name__ == "__main__":
    main()
