#!/usr/bin/env -S uv run --script
# /// script
# requires-python = "~=3.12"
# dependencies = []
# ///
"""
DESCRIPTION: Run all symbolic analyses in sequence (extract, conflicts, flow, states, complete, drift). Single entry point.
Usage: ./.opencode/tools/symbolic analyze [--dir PATH] [--output PATH] [--verbose]
"""

from __future__ import annotations
import os as _os
import sys
import types
import json
from pathlib import Path

IMPL_DIR = Path(__file__).resolve().parent
BASE_DIR = IMPL_DIR.parent.parent.parent
DEFAULT_SCAN_DIR = BASE_DIR / ".opencode"
DEFAULT_OUTPUT_DIR = BASE_DIR / "tmp"


def _load_module(module_file: str):
    safe_name = module_file.replace("-", "_")
    source = (IMPL_DIR / module_file).read_text()
    mod = types.ModuleType(safe_name)
    mod.__file__ = str(IMPL_DIR / module_file)
    sys.modules[safe_name] = mod
    exec(compile(source, str(IMPL_DIR / module_file), "exec"), mod.__dict__)
    return mod


def main() -> None:
    if _os.environ.get("OPENCODE_TOOLS_DISPATCHER") != "1":
        print(
            "ERROR: This script must be run via its dispatcher (e.g. ./.opencode/tools/symbolic ...). "
            "Direct invocation is not permitted.",
            file=sys.stderr,
        )
        sys.exit(1)

    import argparse

    parser = argparse.ArgumentParser(description="Run all symbolic analyses")
    parser.add_argument("--dir", type=str, default=str(DEFAULT_SCAN_DIR))
    parser.add_argument("--output", type=str, default=str(DEFAULT_OUTPUT_DIR))
    parser.add_argument("--verbose", action="store_true")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()

    scan_dir = Path(args.dir)
    output_dir = Path(args.output)
    output_dir.mkdir(parents=True, exist_ok=True)

    extract_mod = _load_module("sym-extract")
    extract_result = extract_mod.extract_yaml_blocks(scan_dir, verbose=args.verbose)

    rules = extract_result.rules
    state_machines = extract_result.state_machines
    all_results: dict = {
        "extract": extract_result.to_dict(),
        "conflicts": [],
        "flow": {},
        "states": [],
        "complete": [],
        "drift": [],
    }

    if not rules and not state_machines:
        print("No yaml+symbolic blocks found. Only extraction ran.")
        if args.json:
            print(json.dumps(all_results, indent=2, default=str))
        return

    print(f"\nExtracted: {len(rules)} rules, {len(state_machines)} state machines")

    conflicts_mod = _load_module("sym-conflicts")
    conflicts = conflicts_mod.detect_conflicts(rules)
    all_results["conflicts"] = [c.to_dict() if hasattr(c, 'to_dict') else str(c) for c in conflicts]
    print(f"Conflicts:  {len(conflicts)} found")
    for c in conflicts:
        cd = c.to_dict() if hasattr(c, 'to_dict') else {}
        print(f"  ⚡ {cd.get('rule_a', '?')} ↔ {cd.get('rule_b', '?')}: {cd.get('description', '')}")

    flow_mod = _load_module("sym-flow")
    flow_graph = flow_mod.build_flow_graph(rules)
    flow_anomalies = flow_mod.analyze_flow(flow_graph)
    all_results["flow"] = {
        "node_count": flow_graph.number_of_nodes(),
        "edge_count": flow_graph.number_of_edges(),
        "anomalies": [a.to_dict() if hasattr(a, 'to_dict') else str(a) for a in flow_anomalies],
    }
    print(f"Flow:       {flow_graph.number_of_nodes()} nodes, {flow_graph.number_of_edges()} edges, {len(flow_anomalies)} anomalies")
    for a in flow_anomalies:
        ad = a.to_dict() if hasattr(a, 'to_dict') else {}
        print(f"  ⚠ {ad.get('node', '?')}: {ad.get('anomaly_type', '')} — {ad.get('description', '')}")

    states_mod = _load_module("sym-states")
    state_anomalies = states_mod.validate_state_machines(state_machines, rules)
    all_results["states"] = [a.to_dict() if hasattr(a, 'to_dict') else str(a) for a in state_anomalies]
    print(f"States:     {len(state_anomalies)} anomalies")
    for a in state_anomalies:
        ad = a.to_dict() if hasattr(a, 'to_dict') else {}
        print(f"  ⚠ {ad.get('machine_id', '?')}/{ad.get('state', '?')}: {ad.get('anomaly_type', '')}")

    complete_mod = _load_module("sym-complete")
    completeness_gaps = complete_mod.check_completeness(rules, scan_dir)
    all_results["complete"] = [g.to_dict() if hasattr(g, 'to_dict') else str(g) for g in completeness_gaps]
    print(f"Completeness: {len(completeness_gaps)} gaps")
    for g in completeness_gaps:
        gd = g.to_dict() if hasattr(g, 'to_dict') else {}
        print(f"  ⚠ {gd.get('type', '?')}: {gd.get('detail', '')}")

    drift_mod = _load_module("sym-drift")
    drift_entries = drift_mod.detect_drift(scan_dir)
    all_results["drift"] = [d.to_dict() if hasattr(d, 'to_dict') else str(d) for d in drift_entries]
    print(f"Drift:      {len(drift_entries)} files drifted")
    for d in drift_entries:
        dd = d.to_dict() if hasattr(d, 'to_dict') else {}
        print(f"  ⚠ {dd.get('file', '?')}: {dd.get('drift_days', 0):.1f} days")

    result_path = output_dir / "symbolic-analysis.json"
    with open(result_path, "w") as f:
        json.dump(all_results, f, indent=2, default=str)
    print(f"\nResults written to {result_path}")

    if args.json:
        print(json.dumps(all_results, indent=2, default=str))


if __name__ == "__main__":
    main()