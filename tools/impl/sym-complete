#!/usr/bin/env -S uv run --script
# /// script
# requires-python = "~=3.12"
# dependencies = []
# ///
"""
DESCRIPTION: Completeness check. Finds uncovered normative terms, dangling cross-refs, rules without prose.
Usage: ./.opencode/tools/symbolic complete
"""

from __future__ import annotations
import os as _os
import re
import sys
import types
from dataclasses import dataclass
from pathlib import Path

IMPL_DIR = Path(__file__).resolve().parent
BASE_DIR = IMPL_DIR.parent.parent.parent
NORMATIVE_RE = re.compile(r"\b(MUST|SHALL|NEVER|ALWAYS|REQUIRED|FORBIDDEN)\b")
YAML_FENCE_RE = re.compile(r"```yaml\+symbolic\n.*?```", re.DOTALL)


def _load_extract():
    source = (IMPL_DIR / "sym-extract").read_text()
    mod = types.ModuleType("symextract")
    mod.__file__ = str(IMPL_DIR / "sym-extract")
    sys.modules["symextract"] = mod
    exec(compile(source, str(IMPL_DIR / "sym-extract"), "exec"), mod.__dict__)
    return mod


@dataclass
class CompletenessGap:
    type: str
    location: str
    detail: str

    def to_dict(self) -> dict:
        return {"type": self.type, "location": self.location, "detail": self.detail}


def _prose_lines(text: str) -> list[tuple[int, str]]:
    lines = text.splitlines()
    result = []
    in_code_block = False
    for i, line in enumerate(lines, 1):
        if line.strip().startswith("```"):
            in_code_block = not in_code_block
            continue
        if not in_code_block:
            result.append((i, line))
    return result


def check_completeness(rules: list, scan_dir: Path) -> list[CompletenessGap]:
    gaps: list[CompletenessGap] = []
    rule_ids = {r.id for r in rules}

    for r in rules:
        for ref in r.conflicts_with + r.requires:
            if ref not in rule_ids:
                gaps.append(CompletenessGap(
                    type="dangling_crossref",
                    location=r.id,
                    detail=f"References non-existent rule '{ref}'",
                ))

    for r in rules:
        if r.source:
            parts = r.source.split("§")
            file_part = parts[0].strip() if parts else r.source
            candidates = list(scan_dir.rglob(f"{Path(file_part).name}*"))
            if not candidates:
                candidates = list(scan_dir.rglob(file_part))
            if not candidates:
                gaps.append(CompletenessGap(
                    type="rule_without_prose",
                    location=r.id,
                    detail=f"Source '{r.source}' not found in scanned files",
                ))

    md_files = sorted(scan_dir.rglob("*.md"))
    for md_file in md_files:
        rel = str(md_file.relative_to(scan_dir))
        try:
            text = md_file.read_text()
        except Exception:
            continue

        prose = _prose_lines(text)
        has_yaml_block = bool(YAML_FENCE_RE.search(text))

        normative_lines = []
        for lineno, line in prose:
            if NORMATIVE_RE.search(line):
                normative_lines.append((lineno, line.strip()))

        if normative_lines and not has_yaml_block:
            gaps.append(CompletenessGap(
                type="uncovered_ref",
                location=rel,
                detail=f"File has {len(normative_lines)} normative statements but no yaml+symbolic block (e.g., line {normative_lines[0][0]})",
            ))

    return gaps


def main() -> None:
    if _os.environ.get("OPENCODE_TOOLS_DISPATCHER") != "1":
        print(
            "ERROR: This script must be run via its dispatcher (e.g. ./.opencode/tools/symbolic ...). "
            "Direct invocation is not permitted.",
            file=sys.stderr,
        )
        sys.exit(1)

    import argparse

    parser = argparse.ArgumentParser(description="Completeness check")
    parser.add_argument("--dir", type=str, default=str(BASE_DIR / ".opencode"))
    args = parser.parse_args()

    mod = _load_extract()
    result = mod.extract_yaml_blocks(Path(args.dir))
    gaps = check_completeness(result.rules, Path(args.dir))

    if gaps:
        print(f"Found {len(gaps)} completeness gaps:")
        for g in gaps:
            print(f"  [{g.type}] {g.location}: {g.detail}")
    else:
        print("No completeness gaps found.")


if __name__ == "__main__":
    main()