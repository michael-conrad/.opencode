#!/usr/bin/env -S uv run --script
# /// script
# requires-python = "~=3.12"
# dependencies = ["pyyaml>=6.0"]
# ///
"""
DESCRIPTION: Missing mandatory decomposition entries — finds dispatch chain steps missing mandatory:true decomposition entries in task contracts.
Usage: ./.opencode/tools/skildeck lint --analysis decomposition [--json] [--verbose]
"""

from __future__ import annotations

import json
import os as _os
import subprocess
import sys
import types
from dataclasses import dataclass, asdict
from pathlib import Path

IMPL_DIR = Path(__file__).resolve().parent
_path = IMPL_DIR
while _path.name != ".opencode":
    _path = _path.parent
DEFAULT_SCAN_DIR = _path


def _load_module(module_file: str):
    target = IMPL_DIR / module_file
    source = target.read_text()
    mod = types.ModuleType(module_file.replace("-", "_"))
    mod.__file__ = str(target)
    sys.modules[module_file.replace("-", "_")] = mod
    exec(compile(source, str(target), "exec"), mod.__dict__)
    return mod


DISPATCH_CHAIN_STEPS = [
    {
        "step": "1",
        "skill": "git-workflow",
        "task": "pre-work",
        "label": "Worktree setup and branch verification",
    },
    {
        "step": "2",
        "skill": "divide-and-conquer",
        "task": "assemble-work",
        "label": "Sub-agent dispatch for implementation",
    },
    {
        "step": "3",
        "skill": "verification-before-completion",
        "task": "verify",
        "label": "Success criteria verification",
    },
    {
        "step": "4",
        "skill": "finishing-a-development-branch",
        "task": "checklist",
        "label": "Branch readiness check",
    },
    {
        "step": "5",
        "skill": "git-workflow",
        "task": "review-prep",
        "label": "Push branch, generate compare URL",
    },
]


@dataclass
class DecompositionFinding:
    step: str
    skill: str
    task: str
    finding_type: str
    severity: str
    message: str
    label: str = ""

    def to_dict(self) -> dict:
        return asdict(self)


def analyze_decomposition(
    scan_dir: Path, verbose: bool = False
) -> list[DecompositionFinding]:
    extract_mod = _load_module("sym-extract")
    result = extract_mod.extract_yaml_blocks(scan_dir, verbose=verbose)

    decomposition = result.decomposition
    tasks = result.tasks
    findings: list[DecompositionFinding] = []

    decomp_by_key: dict[str, list] = {}
    for d in decomposition:
        key = f"{d.skill}/{d.task}"
        decomp_by_key.setdefault(key, []).append(d)

    task_by_key: dict[str, list] = {}
    for t in tasks:
        key = f"{t.skill}/{t.id}"
        task_by_key.setdefault(key, []).append(t)

    for step_info in DISPATCH_CHAIN_STEPS:
        key = f"{step_info['skill']}/{step_info['task']}"
        in_decomp = key in decomp_by_key
        in_tasks = key in task_by_key

        if not in_decomp and not in_tasks:
            findings.append(
                DecompositionFinding(
                    step=step_info["step"],
                    skill=step_info["skill"],
                    task=step_info["task"],
                    finding_type="missing_dispatch_step",
                    severity="CRITICAL",
                    message=f"Dispatch chain step {step_info['step']} ({step_info['label']}) has no decomposition entry and no task definition",
                    label=step_info["label"],
                )
            )
        elif not in_decomp:
            findings.append(
                DecompositionFinding(
                    step=step_info["step"],
                    skill=step_info["skill"],
                    task=step_info["task"],
                    finding_type="missing_decomposition_entry",
                    severity="HIGH",
                    message=f"Dispatch chain step {step_info['step']} ({step_info['label']}) has a task definition but no decomposition entry",
                    label=step_info["label"],
                )
            )

        if in_decomp:
            entries = decomp_by_key[key]
            for entry in entries:
                if not entry.mandatory:
                    findings.append(
                        DecompositionFinding(
                            step=step_info["step"],
                            skill=step_info["skill"],
                            task=step_info["task"],
                            finding_type="non_mandatory_dispatch_step",
                            severity="HIGH",
                            message=f"Dispatch chain step {step_info['step']} ({step_info['label']}) decomposition entry has mandatory=false — dispatch chain steps must be mandatory",
                            label=step_info["label"],
                        )
                    )
                if (
                    entry.bypass_violation
                    and "CRITICAL" not in entry.bypass_violation.upper()
                ):
                    findings.append(
                        DecompositionFinding(
                            step=step_info["step"],
                            skill=step_info["skill"],
                            task=step_info["task"],
                            finding_type="weak_bypass_violation",
                            severity="MEDIUM",
                            message=f"Dispatch chain step {step_info['step']} ({step_info['label']}) bypass_violation is not CRITICAL: '{entry.bypass_violation}'",
                            label=step_info["label"],
                        )
                    )

        if in_tasks:
            task_entries = task_by_key[key]
            for t in task_entries:
                if not t.mandatory:
                    findings.append(
                        DecompositionFinding(
                            step=step_info["step"],
                            skill=step_info["skill"],
                            task=step_info["task"],
                            finding_type="non_mandatory_task",
                            severity="HIGH",
                            message=f"Dispatch chain step {step_info['step']} ({step_info['label']}) task has mandatory=false — dispatch chain tasks must be mandatory",
                            label=step_info["label"],
                        )
                    )

    for key, entries in decomp_by_key.items():
        is_dispatch = any(
            f"{s['skill']}/{s['task']}" == key for s in DISPATCH_CHAIN_STEPS
        )
        if not is_dispatch:
            for entry in entries:
                findings.append(
                    DecompositionFinding(
                        step="",
                        skill=entry.skill,
                        task=entry.task,
                        finding_type="extra_decomposition_entry",
                        severity="LOW",
                        message=f"Decomposition entry {entry.skill}/{entry.task} not in dispatch chain — verify it should exist",
                        label=entry.type,
                    )
                )

    return findings


def main() -> None:
    if _os.environ.get("OPENCODE_TOOLS_DISPATCHER") != "1":
        print(
            "ERROR: This script must be run via its dispatcher. Direct invocation is not permitted.",
            file=sys.stderr,
        )
        sys.exit(1)

    import argparse

    parser = argparse.ArgumentParser(
        description="Missing mandatory decomposition entries analysis"
    )
    parser.add_argument("--dir", type=str, default=str(DEFAULT_SCAN_DIR))
    parser.add_argument("--verbose", action="store_true")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()

    scan_dir = Path(args.dir)
    if not scan_dir.exists():
        print(f"Error: directory not found: {scan_dir}", file=sys.stderr)
        sys.exit(1)

    findings = analyze_decomposition(scan_dir, verbose=args.verbose)

    if args.json:
        print(json.dumps([f.to_dict() for f in findings], indent=2))
    else:
        severity_order = {"CRITICAL": 0, "HIGH": 1, "MEDIUM": 2, "LOW": 3}
        findings.sort(key=lambda f: (severity_order.get(f.severity, 4), f.step))
        print(f"Decomposition Analysis — {len(findings)} findings")
        by_sev: dict[str, list[DecompositionFinding]] = {}
        for f in findings:
            by_sev.setdefault(f.severity, []).append(f)
        for sev in ("CRITICAL", "HIGH", "MEDIUM", "LOW"):
            items = by_sev.get(sev, [])
            if items:
                print(f"\n{sev} ({len(items)}):")
                for item in items:
                    step_str = f"Step {item.step}: " if item.step else ""
                    print(f"  {step_str}{item.skill}/{item.task} — {item.finding_type}")
                    print(f"    {item.message}")


if __name__ == "__main__":
    main()
