#!/usr/bin/env -S uv run python
"""
DESCRIPTION: Drift detection. Compares YAML last_updated timestamps against file mtime.
Usage: uv run python .opencode/tools/symbolic drift
"""

from __future__ import annotations
import os as _os
import re
import sys
from dataclasses import dataclass
from datetime import datetime
from pathlib import Path

BASE_DIR = Path(__file__).resolve().parent.parent.parent.parent
FENCE_PATTERN = re.compile(r"```yaml\+symbolic\n(.*?)```", re.DOTALL)


@dataclass
class DriftEntry:
    file: str
    yaml_last_updated: str
    file_mtime: str
    drift_days: float

    def to_dict(self) -> dict:
        return {
            "file": self.file,
            "yaml_last_updated": self.yaml_last_updated,
            "file_mtime": self.file_mtime,
            "drift_days": self.drift_days,
        }


def detect_drift(scan_dir: Path) -> list[DriftEntry]:
    import yaml
    entries: list[DriftEntry] = []

    md_files = sorted(scan_dir.rglob("*.md"))
    for md_file in md_files:
        rel = str(md_file.relative_to(scan_dir))
        try:
            text = md_file.read_text()
            file_mtime_ts = md_file.stat().st_mtime
        except Exception:
            continue

        for match in FENCE_PATTERN.finditer(text):
            yaml_text = match.group(1)
            try:
                data = yaml.safe_load(yaml_text)
            except yaml.YAMLError:
                continue
            if not isinstance(data, dict):
                continue

            last_updated = data.get("last_updated", "")
            if not last_updated:
                continue

            try:
                yaml_dt = datetime.fromisoformat(last_updated.replace("Z", "+00:00"))
                yaml_ts = yaml_dt.timestamp()
            except (ValueError, OSError):
                continue

            file_mtime_dt = datetime.fromtimestamp(file_mtime_ts)
            drift_seconds = file_mtime_ts - yaml_ts
            if drift_seconds > 0:
                drift_days = drift_seconds / 86400
                entries.append(DriftEntry(
                    file=rel,
                    yaml_last_updated=last_updated,
                    file_mtime=file_mtime_dt.isoformat(),
                    drift_days=drift_days,
                ))

    return entries


def main() -> None:
    if _os.environ.get("OPENCODE_TOOLS_DISPATCHER") != "1":
        print(
            "ERROR: This script must be run via its dispatcher (e.g. uv run python .opencode/tools/symbolic ...). "
            "Direct invocation is not permitted.",
            file=sys.stderr,
        )
        sys.exit(1)

    import argparse

    parser = argparse.ArgumentParser(description="Drift detection")
    parser.add_argument("--dir", type=str, default=str(BASE_DIR / ".opencode"))
    args = parser.parse_args()

    entries = detect_drift(Path(args.dir))
    if entries:
        print(f"Found {len(entries)} files with drift:")
        for e in entries:
            print(f"  {e.file}: {e.drift_days:.1f} days drift (yaml: {e.yaml_last_updated}, file: {e.file_mtime})")
    else:
        print("No drift detected.")


if __name__ == "__main__":
    main()