    rule_id: str
    rule_title: str
    finding_type: str
    severity: str
    message: str
    mapped_skills: list[str] = field(default_factory=list)
    mapped_tasks: list[str] = field(default_factory=list)

    def to_dict(self) -> dict:
        return asdict(self)


