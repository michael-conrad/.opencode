def analyze_enforcement(
    scan_dir: Path, verbose: bool = False
) -> list[EnforcementFinding]:
    extract_mod = _load_module("sym-extract")
    result = extract_mod.extract_yaml_blocks(scan_dir, verbose=verbose)

    rules = result.rules
    findings: list[EnforcementFinding] = []

    rule_enforcement: dict[str, dict] = {}
    for rule in rules:
        matched_skills: set[str] = set()
        matched_tasks: set[str] = set()
        for trigger in rule.triggers:
            matched_skills.add(trigger)
        for pattern_def in ENFORCEMENT_PATTERNS:
            if re.search(pattern_def["rule_pattern"], rule.title, re.IGNORECASE):
                for s in pattern_def["skills"]:
                    matched_skills.add(s)
                for t in pattern_def["tasks"]:
                    matched_tasks.add(t)

        rule_enforcement[rule.id] = {
            "rule": rule,
            "skills": sorted(matched_skills),
            "tasks": sorted(matched_tasks),
        }

    for rule_id, info in rule_enforcement.items():
        rule = info["rule"]
        skills = info["skills"]
        tasks = info["tasks"]

        if not skills and not tasks and not rule.triggers:
            findings.append(
                EnforcementFinding(
                    rule_id=rule.id,
                    rule_title=rule.title,
                    finding_type="no_enforcement",
                    severity="CRITICAL",
                    message=f"Rule {rule.id} has no skill task enforcement mapping and no triggers",
                    mapped_skills=[],
                    mapped_tasks=[],
                )
            )
        elif not tasks and not rule.triggers:
            findings.append(
                EnforcementFinding(
                    rule_id=rule.id,
                    rule_title=rule.title,
                    finding_type="no_task_enforcement",
                    severity="HIGH",
                    message=f"Rule {rule.id} maps to skills but no specific task enforcement checkpoints",
                    mapped_skills=skills,
                    mapped_tasks=[],
                )
            )
        elif rule.triggers and not tasks:
            findings.append(
                EnforcementFinding(
                    rule_id=rule.id,
                    rule_title=rule.title,
                    finding_type="trigger_only_no_task",
                    severity="MEDIUM",
                    message=f"Rule {rule.id} has triggers but no decomposition task enforcement entry",
                    mapped_skills=skills,
                    mapped_tasks=[],
                )
            )

    critical_rules_source = scan_dir / "guidelines" / "000-critical-rules.md"
    if critical_rules_source.exists():
        try:
            text = critical_rules_source.read_text()
            section_headers = re.findall(
                r"^##\s+Critical Violation:\s+(.+)$", text, re.MULTILINE
            )
            for header in section_headers:
                header_clean = header.strip()
                found_in_registry = any(
                    re.search(pattern["rule_pattern"], header_clean, re.IGNORECASE)
                    for pattern in ENFORCEMENT_PATTERNS
                )
                found_in_rules = any(
                    header_clean.lower() in rule.title.lower()
                    or rule.title.lower() in header_clean.lower()
                    for rule in rules
                )
                if not found_in_registry and not found_in_rules:
                    findings.append(
                        EnforcementFinding(
                            rule_id="(critical-rules-section)",
                            rule_title=header_clean[:80],
                            finding_type="critical_rule_no_registry_entry",
                            severity="HIGH",
                            message=f"Critical violation section not mapped in registry: '{header_clean[:60]}'",
                            mapped_skills=[],
                            mapped_tasks=[],
                        )
                    )
        except Exception:
            pass

    return findings


def main() -> None:
    if _os.environ.get("OPENCODE_TOOLS_DISPATCHER") != "1":
        print(
            "ERROR: This script must be run via its dispatcher. Direct invocation is not permitted.",
            file=sys.stderr,
        )
        sys.exit(1)

    import argparse

    parser = argparse.ArgumentParser(
        description="Critical rules → skill task enforcement mapping"
    )
    parser.add_argument("--dir", type=str, default=str(DEFAULT_SCAN_DIR))
    parser.add_argument("--verbose", action="store_true")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()

    scan_dir = Path(args.dir)
    if not scan_dir.exists():
        print(f"Error: directory not found: {scan_dir}", file=sys.stderr)
        sys.exit(1)

    findings = analyze_enforcement(scan_dir, verbose=args.verbose)

    if args.json:
        print(json.dumps([f.to_dict() for f in findings], indent=2))
    else:
        severity_order = {"CRITICAL": 0, "HIGH": 1, "MEDIUM": 2, "LOW": 3}
        findings.sort(key=lambda f: severity_order.get(f.severity, 4))
        print(f"Enforcement Analysis — {len(findings)} findings")
        by_sev: dict[str, list[EnforcementFinding]] = {}
        for f in findings:
            by_sev.setdefault(f.severity, []).append(f)
        for sev in ("CRITICAL", "HIGH", "MEDIUM", "LOW"):
            items = by_sev.get(sev, [])
            if items:
                print(f"\n{sev} ({len(items)}):")
                for item in items:
                    print(f"  [{item.rule_id}] {item.finding_type}: {item.message}")
                    if item.mapped_skills:
                        print(f"    skills: {', '.join(item.mapped_skills)}")
                    if item.mapped_tasks:
                        print(f"    tasks: {', '.join(item.mapped_tasks)}")


if __name__ == "__main__":
    main()
