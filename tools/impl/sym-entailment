#!/usr/bin/env -S uv run --script
# /// script
# requires-python = "~=3.12"
# dependencies = ["pyyaml>=6.0"]
# ///
"""
DESCRIPTION: Pre/post entailment checking — finds contract gaps where upstream postconditions don't satisfy downstream preconditions.
Usage: ./.opencode/tools/skildeck lint --analysis entailment [--json] [--verbose]
"""

from __future__ import annotations

import json
import os as _os
import subprocess
import sys
import types
from dataclasses import dataclass, asdict
from pathlib import Path

IMPL_DIR = Path(__file__).resolve().parent
_git_out = subprocess.check_output(
    ["git", "-C", str(IMPL_DIR), "rev-parse", "--show-superproject-working-tree", "--show-toplevel"], text=True
).strip()
BASE_DIR = Path(_git_out.splitlines()[0]) if _git_out.splitlines() else Path.cwd()
DEFAULT_SCAN_DIR = BASE_DIR / ".opencode"


def _load_module(module_file: str):
    target = IMPL_DIR / module_file
    source = target.read_text()
    mod = types.ModuleType(module_file.replace("-", "_"))
    mod.__file__ = str(target)
    sys.modules[module_file.replace("-", "_")] = mod
    exec(compile(source, str(target), "exec"), mod.__dict__)
    return mod


def _parse_condition(condition: str) -> tuple[str, str, str]:
    for op in ("==", "!=", ">=", "<=", ">", "<"):
        if op in condition:
            parts = condition.split(op, 1)
            return parts[0].strip(), op, parts[1].strip().strip("'\"")
    return condition.strip(), "exists", ""


@dataclass
class EntailmentGap:
    upstream_task_id: str
    upstream_skill: str
    downstream_task_id: str
    downstream_skill: str
    missing_preconditions: list[str]
    severity: str
    message: str

    def to_dict(self) -> dict:
        return asdict(self)


def analyze_entailment(scan_dir: Path, verbose: bool = False) -> list[EntailmentGap]:
    extract_mod = _load_module("sym-extract")
    result = extract_mod.extract_yaml_blocks(scan_dir, verbose=verbose)

    tasks = result.tasks
    decomposition = result.decomposition
    gaps: list[EntailmentGap] = []

    chain: list[tuple] = []
    for d in decomposition:
        matched_tasks = [t for t in tasks if t.skill == d.skill and t.id == d.task]
        if matched_tasks:
            chain.append((d, matched_tasks[0]))
        else:
            partial = [t for t in tasks if t.skill == d.skill]
            if partial:
                chain.append((d, partial[0]))

    if len(chain) < 2:
        for i in range(len(tasks)):
            for j in range(len(tasks)):
                if i == j:
                    continue
                t_up = tasks[i]
                t_down = tasks[j]
                if t_up.skill == t_down.skill:
                    post_set = {p.strip() for p in t_up.postconditions if p.strip()}
                    pre_set = {p.strip() for p in t_down.preconditions if p.strip()}
                    unsatisfied = pre_set - post_set
                    if unsatisfied:
                        sev = "CRITICAL" if t_down.mandatory else "HIGH"
                        gaps.append(
                            EntailmentGap(
                                upstream_task_id=t_up.id,
                                upstream_skill=t_up.skill,
                                downstream_task_id=t_down.id,
                                downstream_skill=t_down.skill,
                                missing_preconditions=sorted(unsatisfied),
                                severity=sev,
                                message=f"Task {t_up.id} postconditions do not satisfy {t_down.id} preconditions: missing {', '.join(sorted(unsatisfied))}",
                            )
                        )
        return gaps

    for k in range(len(chain) - 1):
        d_up, t_up = chain[k]
        d_down, t_down = chain[k + 1]

        post_set = {p.strip() for p in t_up.postconditions if p.strip()}
        pre_set = {p.strip() for p in t_down.preconditions if p.strip()}

        unsatisfied = pre_set - post_set

        if unsatisfied:
            sev = "CRITICAL" if t_down.mandatory else "HIGH"
            gaps.append(
                EntailmentGap(
                    upstream_task_id=t_up.id,
                    upstream_skill=t_up.skill,
                    downstream_task_id=t_down.id,
                    downstream_skill=t_down.skill,
                    missing_preconditions=sorted(unsatisfied),
                    severity=sev,
                    message=f"Chain gap: {t_up.skill}/{t_up.id} → {t_down.skill}/{t_down.id}: postconditions don't satisfy preconditions: {', '.join(sorted(unsatisfied))}",
                )
            )

    for t in tasks:
        if t.preconditions and not any(d.task == t.id for d in decomposition):
            sev = "MEDIUM" if t.mandatory else "LOW"
            gaps.append(
                EntailmentGap(
                    upstream_task_id="(no upstream)",
                    upstream_skill="",
                    downstream_task_id=t.id,
                    downstream_skill=t.skill,
                    missing_preconditions=sorted(
                        {p.strip() for p in t.preconditions if p.strip()}
                    ),
                    severity=sev,
                    message=f"Task {t.skill}/{t.id} has preconditions but no upstream decomposition entry provides them",
                )
            )

    for t in tasks:
        if not t.postconditions and t.mandatory:
            has_downstream = any(
                dt
                for dt in tasks
                if dt.skill != t.skill
                and any(pre.startswith(t.id) or t.id in pre for pre in dt.preconditions)
            )
            if has_downstream:
                gaps.append(
                    EntailmentGap(
                        upstream_task_id=t.id,
                        upstream_skill=t.skill,
                        downstream_task_id="(downstream)",
                        downstream_skill="",
                        missing_preconditions=["(no postconditions defined)"],
                        severity="MEDIUM",
                        message=f"Mandatory task {t.skill}/{t.id} has empty postconditions but may have downstream dependents",
                    )
                )

    return gaps


def main() -> None:
    if _os.environ.get("OPENCODE_TOOLS_DISPATCHER") != "1":
        print(
            "ERROR: This script must be run via its dispatcher. Direct invocation is not permitted.",
            file=sys.stderr,
        )
        sys.exit(1)

    import argparse

    parser = argparse.ArgumentParser(description="Pre/post entailment checking")
    parser.add_argument("--dir", type=str, default=str(DEFAULT_SCAN_DIR))
    parser.add_argument("--verbose", action="store_true")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()

    scan_dir = Path(args.dir)
    if not scan_dir.exists():
        print(f"Error: directory not found: {scan_dir}", file=sys.stderr)
        sys.exit(1)

    gaps = analyze_entailment(scan_dir, verbose=args.verbose)

    if args.json:
        print(json.dumps([g.to_dict() for g in gaps], indent=2))
    else:
        severity_order = {"CRITICAL": 0, "HIGH": 1, "MEDIUM": 2, "LOW": 3}
        gaps.sort(key=lambda g: severity_order.get(g.severity, 4))
        print(f"Entailment Analysis — {len(gaps)} gaps found")
        by_sev: dict[str, list[EntailmentGap]] = {}
        for g in gaps:
            by_sev.setdefault(g.severity, []).append(g)
        for sev in ("CRITICAL", "HIGH", "MEDIUM", "LOW"):
            items = by_sev.get(sev, [])
            if items:
                print(f"\n{sev} ({len(items)}):")
                for item in items:
                    chain = f"{item.upstream_skill}/{item.upstream_task_id} → {item.downstream_skill}/{item.downstream_task_id}"
                    print(f"  {chain}")
                    print(f"    {item.message}")
                    if item.missing_preconditions:
                        print(f"    missing: {', '.join(item.missing_preconditions)}")


if __name__ == "__main__":
    main()
