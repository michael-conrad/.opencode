#!/usr/bin/env -S uv run --script
# /// script
# requires-python = "~=3.12"
# dependencies = ["pyyaml>=6.0"]
# ///
"""
DESCRIPTION: Exhaustive pairwise SAT analysis — finds undeclared contradictions where two rules say HALT and PROCEED under overlapping conditions.
Usage: ./.opencode/tools/skildeck lint --analysis exhaustive [--json] [--verbose]
"""

from __future__ import annotations

import json
import os as _os
import subprocess
import sys
import types
from dataclasses import dataclass, field, asdict
from pathlib import Path

IMPL_DIR = Path(__file__).resolve().parent
CDUP = subprocess.check_output(
    ["git", "-C", str(IMPL_DIR), "rev-parse", "--show-cdup"], text=True
).strip()
BASE_DIR = (IMPL_DIR / CDUP).resolve()
DEFAULT_SCAN_DIR = BASE_DIR / ".opencode"


def _load_module(module_file: str):
    target = IMPL_DIR / module_file
    source = target.read_text()
    mod = types.ModuleType(module_file.replace("-", "_"))
    mod.__file__ = str(target)
    sys.modules[module_file.replace("-", "_")] = mod
    exec(compile(source, str(target), "exec"), mod.__dict__)
    return mod


def _normalize_action(action: str) -> str:
    a = action.strip().upper()
    if a.startswith("HALT"):
        return "HALT"
    if a.startswith("PROCEED"):
        return "PROCEED"
    if a.startswith("INVOKE"):
        return "INVOKE"
    if a.startswith("SET("):
        return "SET"
    if a.startswith("SKIP"):
        return "SKIP"
    if a.startswith("REVOKE"):
        return "REVOKE"
    if a.startswith("RESTRUCTURE"):
        return "RESTRUCTURE"
    if a.startswith("AUTO_APPROVE"):
        return "AUTO_APPROVE"
    if a.startswith("GAP_FILL"):
        return "GAP_FILL"
    if a.startswith("SEARCH"):
        return "SEARCH"
    if a.startswith("PRESENT"):
        return "PRESENT"
    if a.startswith("PARSE_SCOPE"):
        return "PARSE_SCOPE"
    if a.startswith("REPORT"):
        return "REPORT"
    if a.startswith("VIOLATION"):
        return "VIOLATION"
    if a.startswith("REMOVE_LABEL"):
        return "REMOVE_LABEL"
    if a.startswith("ADD_COMMENT"):
        return "ADD_COMMENT"
    return a.split("(")[0].split()[0] if a else a


def _extract_condition_vars(
    conditions_all: list[str], conditions_any: list[str]
) -> set[str]:
    vars_set = set()
    for c in conditions_all + conditions_any:
        parts = (
            c.replace("==", " ")
            .replace("!=", " ")
            .replace(">=", " ")
            .replace("<=", " ")
            .replace(">", " ")
            .replace("<", " ")
        )
        for p in parts.split():
            if (
                not p.startswith(("'", '"'))
                and not p.replace(".", "").replace("-", "").isdigit()
            ):
                vars_set.add(p)
    return vars_set


def _conditions_overlap(r1, r2) -> bool:
    v1 = _extract_condition_vars(r1.conditions_all, r1.conditions_any)
    v2 = _extract_condition_vars(r2.conditions_all, r2.conditions_any)
    if v1 & v2:
        return True
    if r1.conditions_all and r2.conditions_all:
        s1 = set(r1.conditions_all)
        s2 = set(r2.conditions_all)
        conflict = s1 & s2
        if conflict:
            return True
        opposite = set()
        for c in s1:
            if "==" in c:
                left, right = c.split("==", 1)
                opposite.add(f"{left}!={right}")
            elif "!=" in c:
                left, right = c.split("!=", 1)
                opposite.add(f"{left}=={right}")
        if opposite & s2:
            return False
    return bool(v1 & v2) if v1 and v2 else False


@dataclass
class ExhaustiveFinding:
    rule_a_id: str
    rule_b_id: str
    finding_type: str
    severity: str
    message: str
    condition_overlap: list[str] = field(default_factory=list)
    declared_conflict: bool = False

    def to_dict(self) -> dict:
        return asdict(self)


def analyze_exhaustive(
    scan_dir: Path, verbose: bool = False
) -> list[ExhaustiveFinding]:
    extract_mod = _load_module("sym-extract")
    result = extract_mod.extract_yaml_blocks(scan_dir, verbose=verbose)
    rules = result.rules
    findings: list[ExhaustiveFinding] = []

    conflict_pairs: set[frozenset[str]] = set()
    for r in rules:
        for c in r.conflicts_with:
            conflict_pairs.add(frozenset({r.id, c}))

    halt_actions = {"HALT"}
    proceed_actions = {"PROCEED", "AUTO_APPROVE", "SET"}

    for i, r1 in enumerate(rules):
        for j, r2 in enumerate(rules):
            if j <= i:
                continue
            pair = frozenset({r1.id, r2.id})
            is_declared = pair in conflict_pairs

            r1_actions = {_normalize_action(a) for a in r1.actions}
            r2_actions = {_normalize_action(a) for a in r2.actions}

            r1_has_halt = bool(r1_actions & halt_actions)
            r1_has_proceed = bool(r1_actions & proceed_actions)
            r2_has_halt = bool(r2_actions & halt_actions)
            r2_has_proceed = bool(r2_actions & proceed_actions)

            overlap = _conditions_overlap(r1, r2)
            overlap_vars = sorted(
                _extract_condition_vars(r1.conditions_all, r1.conditions_any)
                & _extract_condition_vars(r2.conditions_all, r2.conditions_any)
            )

            if (
                overlap
                or r1.requires == r2.requires
                or r1.id in r2.conflicts_with
                or r2.id in r1.conflicts_with
            ):
                if r1_has_halt and r2_has_proceed:
                    findings.append(
                        ExhaustiveFinding(
                            rule_a_id=r1.id,
                            rule_b_id=r2.id,
                            finding_type="halt_proceed_conflict",
                            severity="CRITICAL",
                            message=f"Undeclared contradiction: {r1.id} says HALT while {r2.id} says PROCEED under overlapping conditions",
                            condition_overlap=overlap_vars,
                            declared_conflict=is_declared,
                        )
                    )
                elif r1_has_proceed and r2_has_halt:
                    findings.append(
                        ExhaustiveFinding(
                            rule_a_id=r2.id,
                            rule_b_id=r1.id,
                            finding_type="halt_proceed_conflict",
                            severity="CRITICAL",
                            message=f"Undeclared contradiction: {r2.id} says HALT while {r1.id} says PROCEED under overlapping conditions",
                            condition_overlap=overlap_vars,
                            declared_conflict=is_declared,
                        )
                    )

                if r1_has_halt and r2_has_halt and not is_declared:
                    findings.append(
                        ExhaustiveFinding(
                            rule_a_id=r1.id,
                            rule_b_id=r2.id,
                            finding_type="undeclared_conflict",
                            severity="HIGH",
                            message="Both rules say HALT under overlapping conditions but no conflicts_with declared",
                            condition_overlap=overlap_vars,
                            declared_conflict=False,
                        )
                    )

                if r1_has_proceed and r2_has_proceed and not is_declared and overlap:
                    findings.append(
                        ExhaustiveFinding(
                            rule_a_id=r1.id,
                            rule_b_id=r2.id,
                            finding_type="redundant_proceed",
                            severity="LOW",
                            message="Both rules say PROCEED under overlapping conditions — consider merging or adding conflicts_with",
                            condition_overlap=overlap_vars,
                            declared_conflict=False,
                        )
                    )

    for r in rules:
        if r.conflicts_with:
            for cid in r.conflicts_with:
                conflict_rules = [x for x in rules if x.id == cid]
                if not conflict_rules:
                    findings.append(
                        ExhaustiveFinding(
                            rule_a_id=r.id,
                            rule_b_id=cid,
                            finding_type="dangling_conflict_ref",
                            severity="MEDIUM",
                            message=f"Rule {r.id} declares conflict with {cid} but {cid} not found in registry",
                            condition_overlap=[],
                            declared_conflict=True,
                        )
                    )

    return findings


def main() -> None:
    if _os.environ.get("OPENCODE_TOOLS_DISPATCHER") != "1":
        print(
            "ERROR: This script must be run via its dispatcher. Direct invocation is not permitted.",
            file=sys.stderr,
        )
        sys.exit(1)

    import argparse

    parser = argparse.ArgumentParser(description="Exhaustive pairwise SAT analysis")
    parser.add_argument("--dir", type=str, default=str(DEFAULT_SCAN_DIR))
    parser.add_argument("--verbose", action="store_true")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()

    scan_dir = Path(args.dir)
    if not scan_dir.exists():
        print(f"Error: directory not found: {scan_dir}", file=sys.stderr)
        sys.exit(1)

    findings = analyze_exhaustive(scan_dir, verbose=args.verbose)

    if args.json:
        print(json.dumps([f.to_dict() for f in findings], indent=2))
    else:
        severity_order = {"CRITICAL": 0, "HIGH": 1, "MEDIUM": 2, "LOW": 3}
        findings.sort(key=lambda f: severity_order.get(f.severity, 4))
        print(f"Exhaustive Pairwise SAT Analysis — {len(findings)} findings")
        by_sev: dict[str, list[ExhaustiveFinding]] = {}
        for f in findings:
            by_sev.setdefault(f.severity, []).append(f)
        for sev in ("CRITICAL", "HIGH", "MEDIUM", "LOW"):
            items = by_sev.get(sev, [])
            if items:
                print(f"\n{sev} ({len(items)}):")
                for item in items:
                    decl = " [DECLARED]" if item.declared_conflict else ""
                    print(
                        f"  {item.rule_a_id} ↔ {item.rule_b_id}: {item.message}{decl}"
                    )
                    if item.condition_overlap:
                        print(
                            f"    overlapping vars: {', '.join(item.condition_overlap)}"
                        )


if __name__ == "__main__":
    main()
