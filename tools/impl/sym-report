#!/usr/bin/env -S uv run python
"""
DESCRIPTION: HTML+SVG report generator. Renders analysis results as self-contained HTML with inline CSS and SVG diagrams.
Usage: uv run python .opencode/tools/symbolic report [--output PATH] [--format html|text]
"""

from __future__ import annotations
import os as _os
import sys
import types
import json
import shutil
import subprocess
from pathlib import Path

import networkx as nx

IMPL_DIR = Path(__file__).resolve().parent
BASE_DIR = IMPL_DIR.parent.parent.parent
DEFAULT_OUTPUT = BASE_DIR / "tmp"


def _load_module(module_file: str):
    safe_name = module_file.replace("-", "_")
    source = (IMPL_DIR / module_file).read_text()
    mod = types.ModuleType(safe_name)
    mod.__file__ = str(IMPL_DIR / module_file)
    sys.modules[safe_name] = mod
    exec(compile(source, str(IMPL_DIR / module_file), "exec"), mod.__dict__)
    return mod


