#!/usr/bin/env -S uv run --script
# /// script
# requires-python = "~=3.12"
# dependencies = ["networkx>=3.1"]
# ///
"""
DESCRIPTION: State machine extraction and validation. Checks reachability, dead states, dangling references.
Usage: ./.opencode/tools/symbolic states
"""

from __future__ import annotations
import os as _os
import sys
import types
from dataclasses import dataclass
from pathlib import Path

import networkx as nx

IMPL_DIR = Path(__file__).resolve().parent
BASE_DIR = IMPL_DIR.parent.parent.parent


def _load_extract():
    source = (IMPL_DIR / "sym-extract").read_text()
    mod = types.ModuleType("symextract")
    mod.__file__ = str(IMPL_DIR / "sym-extract")
    sys.modules["symextract"] = mod
    exec(compile(source, str(IMPL_DIR / "sym-extract"), "exec"), mod.__dict__)
    return mod


@dataclass
class StateAnomaly:
    machine_id: str
    state: str
    anomaly_type: str
    description: str

    def to_dict(self) -> dict:
        return {"machine_id": self.machine_id, "state": self.state, "anomaly_type": self.anomaly_type, "description": self.description}


def validate_state_machines(state_machines: list, rules: list | None = None) -> list[StateAnomaly]:
    anomalies: list[StateAnomaly] = []

    for sm in state_machines:
        if not sm.start_state:
            anomalies.append(StateAnomaly(
                machine_id=sm.id, state="(none)", anomaly_type="missing_start",
                description="State machine has no start_state",
            ))
            continue

        if sm.start_state not in sm.states:
            anomalies.append(StateAnomaly(
                machine_id=sm.id, state=sm.start_state, anomaly_type="invalid_start",
                description=f"start_state '{sm.start_state}' not in states list",
            ))
            continue

        g = nx.DiGraph()
        for s in sm.states:
            g.add_node(s)

        for t in sm.transitions:
            if t.from_state not in sm.states:
                anomalies.append(StateAnomaly(
                    machine_id=sm.id, state=t.from_state, anomaly_type="dangling_ref",
                    description=f"Transition from unknown state '{t.from_state}'",
                ))
            if t.to_state not in sm.states:
                anomalies.append(StateAnomaly(
                    machine_id=sm.id, state=t.to_state, anomaly_type="dangling_ref",
                    description=f"Transition to unknown state '{t.to_state}'",
                ))
            if t.from_state in sm.states and t.to_state in sm.states:
                g.add_edge(t.from_state, t.to_state)

        reachable = set()
        if g.has_node(sm.start_state):
            reachable = {sm.start_state}
            try:
                reachable |= nx.descendants(g, sm.start_state)
            except Exception:
                pass

        for s in sm.states:
            if s not in reachable:
                anomalies.append(StateAnomaly(
                    machine_id=sm.id, state=s, anomaly_type="unreachable",
                    description=f"State '{s}' not reachable from start_state '{sm.start_state}'",
                ))

        try:
            cycles = list(nx.simple_cycles(g))
            for cycle in cycles:
                if len(cycle) > 1:
                    anomalies.append(StateAnomaly(
                        machine_id=sm.id, state="→".join(cycle), anomaly_type="cycle",
                        description=f"Cycle detected: {' → '.join(cycle)} → {cycle[0]}",
                    ))
        except Exception:
            pass

    return anomalies


def main() -> None:
    if _os.environ.get("OPENCODE_TOOLS_DISPATCHER") != "1":
        print(
            "ERROR: This script must be run via its dispatcher (e.g. ./.opencode/tools/symbolic ...). "
            "Direct invocation is not permitted.",
            file=sys.stderr,
        )
        sys.exit(1)

    import argparse

    parser = argparse.ArgumentParser(description="State machine validation")
    parser.add_argument("--dir", type=str, default=str(BASE_DIR / ".opencode"))
    args = parser.parse_args()

    mod = _load_extract()
    result = mod.extract_yaml_blocks(Path(args.dir))
    if not result.state_machines:
        print("No state machines found.")
        sys.exit(0)

    anomalies = validate_state_machines(result.state_machines, result.rules)
    if anomalies:
        print(f"Found {len(anomalies)} anomalies:")
        for a in anomalies:
            print(f"  [{a.anomaly_type}] {a.machine_id}/{a.state}: {a.description}")
    else:
        print("All state machines valid.")


if __name__ == "__main__":
    main()