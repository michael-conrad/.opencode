#!/usr/bin/env -S uv run --script
# /// script
# requires-python = "~=3.12"
# dependencies = ["pyyaml>=6.0"]
# ///
"""
DESCRIPTION: Trigger keyword ambiguity detection — finds multiply-claimed keywords where N>1 skills share the same trigger.
Usage: ./.opencode/tools/skildeck lint --analysis triggers [--json] [--verbose]
"""

from __future__ import annotations

import json
import os as _os
import re
import sys
from collections import defaultdict
from dataclasses import dataclass, field, asdict
from pathlib import Path

def _find_project_root() -> Path:
    current = Path(__file__).resolve().parent
    while current != current.parent:
        if (current / ".opencode").is_dir():
            return current
        current = current.parent
    raise RuntimeError("Could not find project root (no .opencode/ directory found)")

PROJECT_ROOT = _find_project_root()
SKILLS_DIR = PROJECT_ROOT / ".opencode" / "skills"


@dataclass
class TriggerFinding:
    keyword: str
    finding_type: str
    severity: str
    message: str
    skills: list[str] = field(default_factory=list)

    def to_dict(self) -> dict:
        return asdict(self)


def _extract_triggers_from_skill_md(skill_dir: Path) -> tuple[str, list[str]]:
    skill_md = skill_dir / "SKILL.md"
    if not skill_md.exists():
        return skill_dir.name, []
    try:
        text = skill_md.read_text()
    except Exception:
        return skill_dir.name, []

    m = re.search(r"Triggers on:\s*(.+?)(?:\n|\.?\s*\n)", text)
    if not m:
        return skill_dir.name, []

    trigger_text = m.group(1).strip().rstrip(".")
    keywords = [k.strip().lower() for k in trigger_text.split(",") if k.strip()]
    return skill_dir.name, keywords


def analyze_triggers(
    scandir: Path = SKILLS_DIR, verbose: bool = False
) -> list[TriggerFinding]:
    findings: list[TriggerFinding] = []

    if not SKILLS_DIR.exists():
        findings.append(
            TriggerFinding(
                keyword="(no skills directory)",
                finding_type="missing_skills_dir",
                severity="CRITICAL",
                message=f"Skills directory not found: {SKILLS_DIR}",
                skills=[],
            )
        )
        return findings

    skill_triggers: dict[str, list[str]] = {}
    keyword_to_skills: dict[str, list[str]] = defaultdict(list)

    for skill_dir in sorted(SKILLS_DIR.iterdir()):
        if not skill_dir.is_dir():
            continue
        skill_name, keywords = _extract_triggers_from_skill_md(skill_dir)
        if keywords:
            skill_triggers[skill_name] = keywords
            for kw in keywords:
                keyword_to_skills[kw].append(skill_name)

    for skill_name, keywords in sorted(skill_triggers.items()):
        if not keywords:
            findings.append(
                TriggerFinding(
                    keyword="",
                    finding_type="skill_no_triggers",
                    severity="MEDIUM",
                    message=f"Skill '{skill_name}' has no trigger keywords defined",
                    skills=[skill_name],
                )
            )

    for kw, skills in sorted(keyword_to_skills.items()):
        if len(skills) > 1:
            severity = "HIGH" if len(skills) > 2 else "MEDIUM"
            findings.append(
                TriggerFinding(
                    keyword=kw,
                    finding_type="ambiguous_trigger",
                    severity=severity,
                    message=f"Trigger keyword '{kw}' claimed by {len(skills)} skills: {', '.join(sorted(skills))}",
                    skills=sorted(skills),
                )
            )

    for kw, skills in sorted(keyword_to_skills.items()):
        for skill in skills:
            trigger_list = skill_triggers.get(skill, [])
            ambiguous = [
                k for k in trigger_list if len(keyword_to_skills.get(k, [])) > 1
            ]
            if len(ambiguous) == len(trigger_list) and len(trigger_list) > 0:
                findings.append(
                    TriggerFinding(
                        keyword=",".join(ambiguous),
                        finding_type="all_triggers_ambiguous",
                        severity="LOW",
                        message=f"Skill '{skill}' has ALL trigger keywords ambiguous: {', '.join(ambiguous)}",
                        skills=[skill],
                    )
                )
                break

    for kw, skills_list in keyword_to_skills.items():
        same_prefix_skills = set()
        for s1 in skills_list:
            for s2 in skills_list:
                if s1 != s2 and s1.startswith(s2.split("-")[0]):
                    same_prefix_skills.add((s1, s2))
        for s1, s2 in same_prefix_skills:
            s1_triggers = set(skill_triggers.get(s1, []))
            s2_triggers = set(skill_triggers.get(s2, []))
            if s1_triggers and s2_triggers and s1_triggers == s2_triggers:
                findings.append(
                    TriggerFinding(
                        keyword=kw,
                        finding_type="identical_trigger_set",
                        severity="HIGH",
                        message=f"Skills '{s1}' and '{s2}' share identical trigger sets: {', '.join(sorted(s1_triggers))}",
                        skills=sorted([s1, s2]),
                    )
                )

    return findings


def main() -> None:
    if _os.environ.get("OPENCODE_TOOLS_DISPATCHER") != "1":
        print(
            "ERROR: This script must be run via its dispatcher. Direct invocation is not permitted.",
            file=sys.stderr,
        )
        sys.exit(1)

    import argparse

    parser = argparse.ArgumentParser(description="Trigger keyword ambiguity detection")
    parser.add_argument("--dir", type=str, default=str(SKILLS_DIR))
    parser.add_argument("--verbose", action="store_true")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()

    scan_dir = Path(args.dir)
    if not scan_dir.exists():
        print(f"Error: directory not found: {scan_dir}", file=sys.stderr)
        sys.exit(1)

    findings = analyze_triggers(scan_dir, verbose=args.verbose)

    if args.json:
        print(json.dumps([f.to_dict() for f in findings], indent=2))
    else:
        severity_order = {"CRITICAL": 0, "HIGH": 1, "MEDIUM": 2, "LOW": 3}
        findings.sort(key=lambda f: (severity_order.get(f.severity, 4), f.keyword))
        trigger_findings = [
            f for f in findings if f.finding_type == "ambiguous_trigger"
        ]
        other_findings = [f for f in findings if f.finding_type != "ambiguous_trigger"]

        print(
            f"Trigger Analysis — {len(trigger_findings)} ambiguous keywords, {len(other_findings)} other findings"
        )

        if trigger_findings:
            print(f"\nAmbiguous Triggers ({len(trigger_findings)}):")
            for item in trigger_findings:
                mark = "⚠" if item.severity == "HIGH" else "·"
                skills_str = ", ".join(item.skills)
                print(f"  {mark} '{item.keyword}' → {skills_str}")

        for ftype in (
            "skill_no_triggers",
            "all_triggers_ambiguous",
            "identical_trigger_set",
            "missing_skills_dir",
        ):
            items = [f for f in other_findings if f.finding_type == ftype]
            if items:
                print(f"\n{ftype.replace('_', ' ').title()} ({len(items)}):")
                for item in items:
                    print(f"  [{item.severity}] {item.message}")


if __name__ == "__main__":
    main()
