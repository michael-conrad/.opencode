#!/usr/bin/env -S uv run --script
# /// script
# requires-python = "~=3.12"
# dependencies = []
# ///
"""
DESCRIPTION: Markdown tools dispatcher. Usage: ./.opencode/tools/md <action> [args...]
Actions: read, write, add, delete, new
Example: ./.opencode/tools/md read <file.md> [--section <header>]
"""
from __future__ import annotations
import os
import subprocess
import sys
from pathlib import Path

BASE_DIR = Path(__file__).resolve().parent
CDUP = subprocess.check_output(["git", "-C", str(BASE_DIR), "rev-parse", "--show-cdup"], text=True).strip()
PROJECT_ROOT = (BASE_DIR / CDUP).resolve()

ACTIONS = {
    "read": "md-read",
    "write": "md-write",
    "add": "md-add",
    "delete": "md-delete",
    "new": "md-new",
}


def _run_action(script: Path, forwarded_args: list[str], summary: str) -> int:
    result = subprocess.run(
        ["uv", "run", str(script)] + forwarded_args,
        capture_output=True,
        text=True,
        env={**os.environ, "OPENCODE_TOOLS_DISPATCHER": "1"},
    )
    if result.stdout:
        sys.stdout.write(result.stdout)
    if result.stderr:
        sys.stderr.write(result.stderr)
    if result.returncode == 0 and not result.stdout and not result.stderr:
        print(summary)
    return result.returncode


def _get_description(script_path: Path) -> str:
    import re
    try:
        text = script_path.read_text()
        # Find all lines between the first and last triple quotes
        m = re.search(r'"""(.*?)"""', text, re.DOTALL)
        if m:
            docstring = m.group(1).strip()
            # Extract only the DESCRIPTION line
            dm = re.search(r'DESCRIPTION:\s*(.+)', docstring)
            return dm.group(1).strip() if dm else ""
        return ""
    except Exception:
        return ""


def main() -> None:
    args = sys.argv[1:]
    if not args or args[0] in ("-h", "--help", "help"):
        print(__doc__)
        print("Available actions:")
        for action, script in ACTIONS.items():
            desc = _get_description(PROJECT_ROOT / ".opencode" / "tools" / "impl" / script)
            print(f"  {action:<20} — {desc}" if desc else f"  {action:<20} → .opencode/tools/{script}")
        print(f"CWD: {os.getcwd()}")
        sys.exit(0)
    action = args[0]
    if action not in ACTIONS:
        print(f"Error: unknown action {action!r}. Available: {', '.join(ACTIONS)}", file=sys.stderr)
        sys.exit(1)
    script = PROJECT_ROOT / ".opencode" / "tools" / "impl" / ACTIONS[action]
    sys.exit(_run_action(script, args[1:], f"OK: .opencode/tools/md {action} completed."))


if __name__ == "__main__":
    main()
