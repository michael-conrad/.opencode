__doc__ = """Model resolution tool for Ollama — selects smallest VRAM-fitting model for a given target capability.

Usage: tools/ollama-model-resolve [--target enforcement|general|coding]
"""

import json
import subprocess
import sys
from pathlib import Path
from typing import Any


OLLAMA_PROBE = Path(__file__).resolve().parent / "ollama-probe"


def run_ollama_probe(*args: str) -> dict[str, Any]:
    """Run ollama-probe with given args and return parsed JSON, or {} on failure."""
    result = subprocess.run(
        [str(OLLAMA_PROBE), *args],
        capture_output=True, text=True, check=False, timeout=30,
    )
    if result.returncode != 0:
        return {}
    return json.loads(result.stdout)


def select_model(
    hardware: dict[str, Any],
    local_models: list[dict[str, Any]],
    cloud_models: list[dict[str, Any]],
    target: str,
) -> dict[str, Any]:
    """Select smallest VRAM-fitting model for the given target."""
    vram_gb = hardware.get("vram_gb", 0)
    local_only = hardware.get("gpu_count", 0) == 0

    def matches_target(m: dict[str, Any]) -> bool:
        tags = m.get("tags", [])
        return "enforcement" in tags if target == "enforcement" else True

    candidates = [m for m in local_models if matches_target(m)]
    candidates.sort(key=lambda m: m.get("size_gb", 999))

    selected = None
    fallback = None
    selection_reason = ""

    for model in candidates:
        if model.get("size_gb", 999) <= vram_gb:
            selected = model
            selected["provider"] = "local"
            selection_reason = f"Local model {model['name']} fits VRAM ({model['size_gb']}GB <= {vram_gb}GB)"
            break

    if selected is None and cloud_models:
        cloud_candidates = [m for m in cloud_models if matches_target(m)]
        cloud_candidates.sort(key=lambda m: m.get("size_gb", 999))
        if cloud_candidates:
            selected = cloud_candidates[0]
            selected["provider"] = "cloud"
            selection_reason = f"No local model fits VRAM. Using cloud model {selected['name']}"
            remaining = [m for m in cloud_candidates if m != selected]
            if remaining:
                fallback = remaining[0]
        elif cloud_models:
            cloud_candidates = sorted(cloud_models, key=lambda m: m.get("size_gb", 999))
            if cloud_candidates:
                selected = cloud_candidates[0]
                selected["provider"] = "cloud"
                selection_reason = f"No enforcement-capable cloud model. Fallback to {selected['name']}"

    elif selected is None:
        local_only = True
        candidates = sorted(local_models, key=lambda m: m.get("size_gb", 999))
        if candidates:
            selected = candidates[0]
            selected["provider"] = "local"
            selection_reason = f"No VRAM-fitting model. Using smallest: {selected['name']}"

    return {
        "selected": selected,
        "fallback": fallback,
        "local_only": local_only,
        "selection_reason": selection_reason or "No models available",
        "hardware": hardware,
        "candidates_considered": len(local_models) + len(cloud_models),
        "target": target,
    }


def main() -> None:
    target = "enforcement"
    for i, arg in enumerate(sys.argv[1:]):
        if arg.startswith("--target="):
            target = arg.split("=", 1)[1]
        elif arg == "--target" and i + 2 < len(sys.argv):
            target = sys.argv[i + 2]

    hardware = run_ollama_probe("hw")
    local_result = run_ollama_probe("list", "--json")
    local_models = local_result.get("models", [])
    cloud_data = run_ollama_probe("remote", "--capability", "enforcement")
    cloud_models = cloud_data.get("models", [])

    result = select_model(hardware, local_models, cloud_models, target)
    print(json.dumps(result, indent=2))


if __name__ == "__main__":
    main()
