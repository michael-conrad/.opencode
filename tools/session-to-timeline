#!/usr/bin/env python3
"""
session-to-timeline — Extract structured tool call timeline from behavioral test session.yaml.

Reads a session.yaml (JSON export of opencode SQLite DB 'part' table) and produces a
condensed timeline of tool calls, reasoning, and responses for clean-room evaluation.

Usage:
    session-to-timeline <session.yaml> [output.yaml]
    # Default output: <session.yaml dir>/timeline.yaml
"""

import json
import sys
from pathlib import Path


def load_session(path: Path) -> dict:
    with open(path) as f:
        return json.load(f)


def _safe_int(v) -> int | None:
    if v is None:
        return None
    try:
        return int(v)
    except (ValueError, TypeError):
        return None


def extract_timeline(session: dict) -> list[dict]:
    """Extract timeline entries from session part table in order."""
    tables = session.get("tables", {})

    # Primary source: part table (each individual tool call / reasoning / text)
    for tbl_name in ("part", "message", "conversation"):
        tbl = tables.get(tbl_name)
        if tbl and tbl.get("rows"):
            rows = tbl["rows"]
            cols = tbl.get("columns", [])
            # Sort by time_created when available
            if "time_created" in cols:
                rows = sorted(rows, key=lambda r: _safe_int(r.get("time_created", 0)) or 0)
            return _extract_rows(rows)

    return []


def _extract_rows(rows: list[dict]) -> list[dict]:
    timeline = []
    for row in rows:
        data_raw = row.get("data", "")
        if not data_raw or not isinstance(data_raw, str):
            continue

        try:
            data = json.loads(data_raw)
        except (json.JSONDecodeError, TypeError):
            continue

        time_created = _safe_int(row.get("time_created", 0))
        time_updated = _safe_int(row.get("time_updated", 0))
        duration_ms = None
        if time_updated and time_created:
            duration_ms = time_updated - time_created

        entry_type = data.get("type", "")

        if entry_type == "tool":
            tool_call = data.get("tool", "")
            call_id = data.get("callID", "")
            state = data.get("state", {})
            inp = state.get("input", {})
            status = state.get("status", "unknown")
            input_summary = _summarize_input(tool_call, inp)

            timeline.append({
                "type": "tool_call",
                "tool": tool_call,
                "call_id": call_id,
                "status": status,
                "input": input_summary,
                "duration_ms": duration_ms,
            })

        elif entry_type == "reasoning":
            text = data.get("text", "")
            timeline.append({
                "type": "reasoning",
                "summary": text[:200] + ("..." if len(text) > 200 else ""),
                "length": len(text),
            })

        elif entry_type == "text":
            text = data.get("text", "")
            timeline.append({
                "type": "response",
                "preview": text[:300] + ("..." if len(text) > 300 else ""),
                "length": len(text),
            })

    return timeline


TOOL_INPUT_SUMMARIZERS = {
    "bash": lambda inp: {
        "desc": inp.get("description", ""),
        "cmd": inp.get("command", "")[:150] + ("..." if len(inp.get("command", "")) > 150 else ""),
    },
    "read": lambda inp: {
        "file": inp.get("filePath", ""),
        "offset": inp.get("offset"),
        "limit": inp.get("limit"),
    },
    "edit": lambda inp: {
        "file": inp.get("filePath", ""),
        "old_preview": inp.get("oldString", "")[:80],
        "new_preview": inp.get("newString", "")[:80],
    },
    "write": lambda inp: {
        "file": inp.get("filePath", ""),
        "content_length": len(inp.get("content", "")),
    },
    "glob": lambda inp: {
        "pattern": inp.get("pattern", ""),
        "path": inp.get("path", ""),
    },
    "grep": lambda inp: {
        "pattern": inp.get("pattern", ""),
        "path": inp.get("path", ""),
    },
    "github_issue_read": lambda inp: {
        "owner": inp.get("owner"), "repo": inp.get("repo"),
        "issue": inp.get("issue_number"), "method": inp.get("method"),
    },
    "github_issue_write": lambda inp: {
        "owner": inp.get("owner"), "repo": inp.get("repo"),
        "method": inp.get("method"), "title": inp.get("title"),
    },
    "github_search_code": lambda inp: {
        "query": inp.get("query", "")[:100],
    },
    "github_create_pull_request": lambda inp: {
        "title": inp.get("title"), "head": inp.get("head"), "base": inp.get("base"),
    },
    "srclight_search_symbols": lambda inp: {
        "query": inp.get("query", "")[:100], "kind": inp.get("kind"),
    },
    "srclight_get_signature": lambda inp: {"name": inp.get("name", "")},
    "srclight_get_symbol": lambda inp: {"name": inp.get("name", "")},
    "task": lambda inp: {
        "subagent_type": inp.get("subagent_type", ""),
        "description": inp.get("description", "")[:120],
    },
}

FALLBACK_SUMMARIZER = lambda inp: {k: v for k, v in inp.items() if isinstance(v, (str, int, float, bool, type(None)))} if isinstance(inp, dict) else {}


def _summarize_input(tool_call: str, inp: dict) -> dict:
    if not isinstance(inp, dict) or not inp:
        return {}
    for tool_name, summarizer in TOOL_INPUT_SUMMARIZERS.items():
        if tool_call == tool_name or tool_call.startswith(tool_name + "_") or tool_call.startswith(tool_name + "."):
            try:
                return summarizer(inp)
            except Exception:
                return {"_error": "summarizer failed"}
    return FALLBACK_SUMMARIZER(inp)


def write_timeline(timeline: list[dict], output_path: Path) -> None:
    lines = ["# Behavioral Test Timeline", f"# Entries: {len(timeline)}", ""]
    for i, entry in enumerate(timeline):
        etype = entry["type"]
        lines.append(f"--- Step {i + 1} ---")
        lines.append(f"type: {etype}")

        if etype == "tool_call":
            lines.append(f"  tool: {entry['tool']}")
            lines.append(f"  status: {entry['status']}")
            if entry.get("duration_ms"):
                lines.append(f"  duration_ms: {entry['duration_ms']}")
            if entry.get("call_id"):
                lines.append(f"  call_id: {entry['call_id']}")
            inp = entry.get("input", {})
            if inp:
                lines.append("  input:")
                for k, v in inp.items():
                    lines.append(f"    {k}: {v}")

        elif etype == "reasoning":
            lines.append(f"  summary: {entry['summary']}")
            lines.append(f"  length: {entry['length']}")

        elif etype == "response":
            lines.append(f"  preview: {entry['preview']}")
            lines.append(f"  length: {entry['length']}")

        lines.append("")

    output_path.write_text("\n".join(lines))
    print(f"Timeline written to {output_path} ({len(timeline)} entries)")


def main():
    if len(sys.argv) < 2:
        print(__doc__.strip(), file=sys.stderr)
        sys.exit(1)

    session_path = Path(sys.argv[1])
    if not session_path.exists():
        print(f"FATAL: {session_path} not found", file=sys.stderr)
        sys.exit(1)

    output_path = Path(sys.argv[2]) if len(sys.argv) > 2 else session_path.parent / "timeline.yaml"

    session = load_session(session_path)
    timeline = extract_timeline(session)
    write_timeline(timeline, output_path)


if __name__ == "__main__":
    main()