import argparse
import sys
from datetime import datetime, timezone
from pathlib import Path

import yaml
import z3


_path = Path(__file__).resolve().parent
while _path.name != ".opencode":
    _path = _path.parent
PROJECT_ROOT = _path.parent


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------


def _die(msg: str, code: int = 2) -> None:
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(code)


def _normalize_exprs(items) -> list[str]:
    """Normalize precondition/postcondition/invariant items to list of strings.

    Accepts: None, a single string, a list of strings.
    Dict items are rejected with _die() as schema violations.
    """
    if items is None:
        return []
    if not isinstance(items, list):
        items = [items]
    result = []
    for item in items:
        if isinstance(item, dict):
            name = item.get("name", "<unnamed>")
            _die(
                f"contract expression must be a string, got dict "
                f"(name={name!r}). "
                f"Use flat format: '- <z3-expr>'"
            )
        if not isinstance(item, str):
            _die(f"contract expression must be a string, got {type(item).__name__}")
        result.append(item)
    return result


def _load_yaml(path: str) -> dict:
    p = Path(path)
    if not p.exists():
        _die(f"file not found: {path}")
    with p.open() as f:
        data = yaml.safe_load(f)
    if not isinstance(data, dict):
        _die(f"expected a YAML mapping in {path}")
    return data


# ---------------------------------------------------------------------------
# Z3 factory — create constants from contract variable declarations
# ---------------------------------------------------------------------------

_Z3_SORT = {
    "bool": z3.BoolSort(),
    "string": z3.StringSort(),
    "int": z3.IntSort(),
    "real": z3.RealSort(),
}


def _make_constants(variables: dict) -> dict[str, z3.ExprRef]:
    """Return {name: z3-constant} for each variable declared in contract."""
    consts = {}
    for name, decl in variables.items():
        if not isinstance(decl, dict):
            _die(f"variable {name!r} declaration must be a mapping")
        typ = decl.get("type", "bool")
        sort = _Z3_SORT.get(typ)
        if sort is None:
            _die(f"unsupported variable type {typ!r} for {name!r}")
        consts[name] = z3.Const(name, sort)
    return consts


# ---------------------------------------------------------------------------
# Expression evaluator — eval() with Z3 constants and z3 module
# ---------------------------------------------------------------------------


def _eval_expr(expr: str, consts: dict[str, z3.ExprRef]) -> z3.BoolRef:
    ctx = {**consts, "z3": z3}
    try:
        result = eval(expr, {"__builtins__": {}}, ctx)
    except Exception as exc:
        _die(f"cannot evaluate expression {expr!r}: {exc}")
    if not isinstance(result, z3.BoolRef):
        _die(
            f"expression {expr!r} does not evaluate to a BoolRef (got {type(result).__name__})"
        )
    return result


# ---------------------------------------------------------------------------
# Model printer
# ---------------------------------------------------------------------------


def _print_model(model: z3.Model, consts: dict[str, z3.ExprRef]) -> None:
    for name in sorted(consts):
        val = model.eval(consts[name], model_completion=True)
        print(f"  {name} = {val}")


# ---------------------------------------------------------------------------
# State helpers
# ---------------------------------------------------------------------------


def _state_path(path: str) -> Path:
    p = Path(path)
    if not p.suffix:
        p = p / "state.yaml"
    return p


# ---------------------------------------------------------------------------
# Action: check
# ---------------------------------------------------------------------------


def _action_check(args: argparse.Namespace) -> None:
    state_data = _load_yaml(args.state_path)
    contract = _load_yaml(args.contract_path)

    variables = contract.get("variables", {})
    consts = _make_constants(variables)

    solver = z3.Solver()
    solver.set("core.minimize", True)

    # Assert state values as equalities
    state_vars = state_data.get("variables", state_data)
    for name, decl in variables.items():
        if name in state_vars:
            val = state_vars[name]
            z3val = _py_to_z3(val, decl, consts[name])
            solver.add(consts[name] == z3val)

    # Assert preconditions
    for expr in _normalize_exprs(contract.get("preconditions")):
        solver.add(_eval_expr(expr, consts))

    # Check SAT after preconditions
    sat_pre = solver.check()
    if sat_pre == z3.sat:
        print("SAT")
        _print_model(solver.model(), consts)
    else:
        core = solver.unsat_core()
        labels = [str(c) for c in core] if core else ["(no labels)"]
        print("UNSAT")
        for lbl in labels:
            print(f"  label: {lbl}")
        return

    # Add postconditions + invariants, re-check
    for expr in _normalize_exprs(contract.get("postconditions")):
        solver.add(_eval_expr(expr, consts))

    for expr in _normalize_exprs(contract.get("invariants")):
        solver.add(_eval_expr(expr, consts))

    sat_post = solver.check()
    if sat_post == z3.sat:
        print("SAT (+ postconditions + invariants)")
        _print_model(solver.model(), consts)
    else:
        core = solver.unsat_core()
        labels = [str(c) for c in core] if core else ["(no labels)"]
        print("UNSAT (+ postconditions + invariants)")
        for lbl in labels:
            print(f"  label: {lbl}")
        sys.exit(1)


# ---------------------------------------------------------------------------
# Action: model
# ---------------------------------------------------------------------------


def _action_model(args: argparse.Namespace) -> None:
    contract = _load_yaml(args.contract_path)
    variables = contract.get("variables", {})
    consts = _make_constants(variables)

    solver = z3.Solver()

    # Contract constraints: preconditions + invariants
    for expr in _normalize_exprs(contract.get("preconditions")):
        solver.add(_eval_expr(expr, consts))

    for expr in _normalize_exprs(contract.get("invariants")):
        solver.add(_eval_expr(expr, consts))

    # Query constraint
    solver.add(_eval_expr(args.query, consts))

    sat = solver.check()
    if sat == z3.sat:
        print("SAT")
        _print_model(solver.model(), consts)
    else:
        print("UNSAT")
        sys.exit(1)


# ---------------------------------------------------------------------------
# Action: prove
# ---------------------------------------------------------------------------


def _action_prove(args: argparse.Namespace) -> None:
    contract = _load_yaml(args.contract_path)
    variables = contract.get("variables", {})
    consts = _make_constants(variables)

    solver = z3.Solver()

    # Assumptions = preconditions + invariants
    for expr in _normalize_exprs(contract.get("preconditions")):
        solver.add(_eval_expr(expr, consts))

    for expr in _normalize_exprs(contract.get("invariants")):
        solver.add(_eval_expr(expr, consts))

    # Negate the theorem
    theorem = _eval_expr(args.theorem, consts)
    solver.add(z3.Not(theorem))

    sat = solver.check()
    if sat == z3.unsat:
        print("VALID")
    else:
        print("INVALID")
        _print_model(solver.model(), consts)
        sys.exit(1)


# ---------------------------------------------------------------------------
# Action: state
# ---------------------------------------------------------------------------


def _py_to_z3(val, decl: dict, const: z3.ExprRef) -> z3.ExprRef:
    typ = decl.get("type", "bool")
    nullable = decl.get("nullable", False)
    domain = decl.get("domain")

    # handle null / empty for nullable
    if nullable and (
        val is None or (isinstance(val, str) and val.strip().lower() in ("", "null"))
    ):
        # no good universal "null" in Z3 sorts; skip constraint
        return const

    if typ == "bool":
        if isinstance(val, bool):
            return z3.BoolVal(val)
        s = str(val).strip().lower()
        if s in ("true", "1", "yes"):
            return z3.BoolVal(True)
        elif s in ("false", "0", "no"):
            return z3.BoolVal(False)
        _die(f"invalid bool value {val!r}")
    elif typ == "int":
        return z3.IntVal(int(val))
    elif typ == "real":
        return z3.RealVal(float(val))
    elif typ == "string":
        s = str(val)
        if domain is not None and s not in domain:
            _die(f"value {s!r} not in domain {domain}")
        return z3.StringVal(s)

    _die(f"unsupported type {typ!r}")


def _action_state_init(path: str) -> None:
    p = _state_path(path)
    p.parent.mkdir(parents=True, exist_ok=True)
    state = {
        "variables": {},
        "timestamp": datetime.now(timezone.utc).isoformat(),
    }
    with p.open("w") as f:
        yaml.dump(state, f, default_flow_style=False)
    print(f"state initialised at {p}")


def _action_state_update(
    path: str, contract_path: str | None, var_name: str | None, var_value: str | None
) -> None:
    p = _state_path(path)
    if not p.exists():
        _die(f"state file not found: {p} (run state init first)", 1)

    data = _load_yaml(str(p))
    variables = data.get("variables", {})

    # Load contract for validation
    contract = None
    schema = None
    if contract_path:
        contract = _load_yaml(contract_path)
        schema = contract.get("variables", {})

    if var_name is not None and var_value is not None:
        if schema and var_name in schema:
            decl = schema[var_name]
            typ = decl.get("type", "bool")
            nullable = decl.get("nullable", False)
            domain = decl.get("domain")

            if nullable and var_value.strip().lower() in ("", "null"):
                variables[var_name] = None
            elif typ == "bool":
                sv = var_value.strip().lower()
                if sv in ("true", "1", "yes"):
                    variables[var_name] = True
                elif sv in ("false", "0", "no"):
                    variables[var_name] = False
                else:
                    _die(f"invalid bool value {var_value!r} for {var_name}")
            elif typ == "int":
                variables[var_name] = int(var_value)
            elif typ == "real":
                variables[var_name] = float(var_value)
            elif typ == "string":
                sv = var_value.strip()
                if domain is not None and sv not in domain:
                    _die(f"value {sv!r} not in domain {domain} for {var_name}")
                variables[var_name] = sv
        else:
            # no schema or unknown var — store as raw string
            variables[var_name] = var_value

    data["variables"] = variables
    data["timestamp"] = datetime.now(timezone.utc).isoformat()

    with p.open("w") as f:
        yaml.dump(data, f, default_flow_style=False)
    print(f"state updated at {p}")


def _action_state_status(path: str) -> None:
    p = _state_path(path)
    if not p.exists():
        _die(f"state file not found: {p}")
    data = _load_yaml(str(p))
    variables = data.get("variables", {})
    ts = data.get("timestamp", "")
    print(f"timestamp: {ts}")
    print("variables:")
    for name, val in sorted(variables.items()):
        print(f"  {name}: {val}")


def _action_state(args: argparse.Namespace) -> None:
    sub = args.state_sub
    path = args.state_path

    if sub == "init":
        _action_state_init(path)
    elif sub == "update":
        _action_state_update(path, args.contract_path, args.var_name, args.var_value)
    elif sub == "status":
        _action_state_status(path)


# ---------------------------------------------------------------------------
# argparse
# ---------------------------------------------------------------------------


def _build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="solve",
        description="Z3 constraint solver for workflow correctness via contract/state files.",
    )
    sub = parser.add_subparsers(dest="action", required=True)

    # check
    p_check = sub.add_parser("check", help="validate state against contract")
    p_check.add_argument("--state-path", required=True)
    p_check.add_argument("--contract-path", required=True)

    # model
    p_model = sub.add_parser("model", help="SAT + satisfying assignment for a query")
    p_model.add_argument("--contract-path", required=True)
    p_model.add_argument("--query", required=True)

    # prove
    p_prove = sub.add_parser("prove", help="theorem proving against contract")
    p_prove.add_argument("--contract-path", required=True)
    p_prove.add_argument("--theorem", required=True)

    # state
    p_state = sub.add_parser("state", help="state file management")
    p_state.add_argument("state_sub", choices=["init", "update", "status"])
    p_state.add_argument("state_path")
    p_state.add_argument("--var-name", "-n")
    p_state.add_argument("--var-value", "-v")
    p_state.add_argument("--contract-path")

    return parser


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------


def main() -> None:
    if len(sys.argv) == 2 and sys.argv[1] == "--description":
        print("Z3 constraint solver for workflow correctness.")
        return
    parser = _build_parser()
    args = parser.parse_args()

    if args.action == "check":
        _action_check(args)
    elif args.action == "model":
        _action_model(args)
    elif args.action == "prove":
        _action_prove(args)
    elif args.action == "state":
        _action_state(args)


if __name__ == "__main__":
    main()
