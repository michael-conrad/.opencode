#!/usr/bin/env -S uv run python
"""
DESCRIPTION: Symbolic analysis engine for guidelines and skills. Usage: uv run python .opencode/tools/symbolic <action> [options]
Actions: extract, extract-dot, conflicts, flow, states, complete, drift, analyze, report, help
Example: uv run python .opencode/tools/symbolic analyze
"""
from __future__ import annotations
import os
import subprocess
import sys
from pathlib import Path

BASE_DIR = Path(__file__).resolve().parent.parent.parent

ACTIONS = {
    "extract": "sym-extract",
    "extract-dot": "sym-extract-dot",
    "conflicts": "sym-conflicts",
    "flow": "sym-flow",
    "states": "sym-states",
    "complete": "sym-complete",
    "drift": "sym-drift",
    "analyze": "sym-analyze",
    "report": "sym-report",
}


def _get_description(script_path: Path) -> str:
    import re
    try:
        text = script_path.read_text()
        m = re.search(r'DESCRIPTION:\s*(.+)', text)
        return m.group(1).strip() if m else ""
    except Exception:
        return ""


def _run_action(script: Path, forwarded_args: list[str], summary: str) -> int:
    result = subprocess.run(
        [sys.executable, str(script)] + forwarded_args,
        capture_output=True,
        text=True,
        env={**os.environ, "OPENCODE_TOOLS_DISPATCHER": "1"},
    )
    if result.stdout:
        sys.stdout.write(result.stdout)
    if result.stderr:
        sys.stderr.write(result.stderr)
    if result.returncode == 0 and not result.stdout and not result.stderr:
        print(summary)
    return result.returncode


def main() -> None:
    args = sys.argv[1:]
    if not args or args[0] in ("-h", "--help", "help"):
        print(__doc__)
        print("Available actions:")
        for action, script in ACTIONS.items():
            desc = _get_description(BASE_DIR / ".opencode" / "tools" / "impl" / script)
            print(f"  {action:<20} — {desc}" if desc else f"  {action:<20} → .opencode/tools/impl/{script}")
        print(f"CWD: {os.getcwd()}")
        sys.exit(0)
    action = args[0]
    if action not in ACTIONS:
        print(f"Error: unknown action {action!r}. Available: {', '.join(ACTIONS)}", file=sys.stderr)
        sys.exit(1)
    script = BASE_DIR / ".opencode" / "tools" / "impl" / ACTIONS[action]
    sys.exit(_run_action(script, args[1:], f"OK: .opencode/tools/symbolic {action} completed."))


if __name__ == "__main__":
    main()